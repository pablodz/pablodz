---
/**
 * Zoom-out continuo por escalas: ADN, célula, persona, familia, barrio, ciudad,
 * nación y mundo. En cada nivel se ven varias unidades agrupadas dentro de una
 * unidad mayor de la misma forma. El viaje siempre se aleja: la unidad del
 * centro se encoge hasta volverse una pieza del grupo siguiente, así el mismo
 * patrón de agrupación se repite subiendo de escala. Al llegar al mundo, el
 * recorrido reinicia limpio desde el ADN.
 */
---

<figure class="czoom panel">
  <figcaption class="czoom-head">
    <span class="czoom-title">◢ A toda escala, la misma forma</span>
    <button class="czoom-btn" data-pause type="button">⏸ Pausar</button>
  </figcaption>
  <canvas data-cv></canvas>
  <p class="czoom-cap">Nos agrupamos igual en cada escala: las células forman un cuerpo, las personas
  una familia, las familias un barrio, y así hasta el mundo. Cada grupo es apenas una pieza de otro
  mayor que se ordena de la misma manera.</p>
  <div class="czoom-foot">DEL ADN AL MUNDO, EL MISMO PATRÓN DE AGRUPACIÓN</div>
</figure>

<script>
  import { ctxOf } from '../lib/machine';

  type Ctx = CanvasRenderingContext2D;

  // Paleta del sitio. Colores contiguos siempre distintos para leer el salto de escala.
  const BG = '#0a0a0c';
  const MUTED = '#8f8b83';
  const SCALES = [
    { name: 'ADN',      col: '#ffcc33' },
    { name: 'célula',   col: '#52d053' },
    { name: 'persona',  col: '#33b7db' },
    { name: 'familia',  col: '#a78bfa' },
    { name: 'barrio',   col: '#ed8d4c' },
    { name: 'ciudad',   col: '#52d053' },
    { name: 'nación',   col: '#a78bfa' },
    { name: 'mundo',    col: '#33b7db' },
  ];
  const N = SCALES.length;

  const RATIO = 3.85;         // radio del grupo madre / radio de la unidad hija
  const MS_PER_LEVEL = 4400;  // una escala cada ~4.4s
  const H_MIN = 340;

  const mod = (k: number, m: number) => ((k % m) + m) % m;
  const clamp01 = (v: number) => (v < 0 ? 0 : v > 1 ? 1 : v);
  const smooth = (v: number) => { const t = clamp01(v); return t * t * (3 - 2 * t); };

  // ---- Siluetas por escala (una forma reconocible por nivel) --------------
  function lw(r: number, base: number) { return Math.max(0.9, r * base); }

  function sil(x: Ctx, name: string, cx: number, cy: number, r: number, col: string, a: number) {
    if (a <= 0.01 || r <= 0.6) return;
    x.save();
    x.strokeStyle = col;
    x.fillStyle = col;
    x.lineJoin = 'round';
    x.lineCap = 'round';
    switch (name) {
      case 'ADN': {
        const top = cy - r * 0.96, bot = cy + r * 0.96, amp = r * 0.4, turns = 2.1;
        x.lineWidth = lw(r, 0.055);
        for (const ph of [0, Math.PI]) {
          x.globalAlpha = a; x.beginPath();
          for (let i = 0; i <= 44; i++) {
            const t = i / 44, y = top + (bot - top) * t;
            const xx = cx + Math.sin(t * Math.PI * 2 * turns + ph) * amp;
            i ? x.lineTo(xx, y) : x.moveTo(xx, y);
          }
          x.stroke();
        }
        x.lineWidth = lw(r, 0.035);
        for (let i = 1; i < 8; i++) {
          const t = i / 8, y = top + (bot - top) * t;
          const x1 = cx + Math.sin(t * Math.PI * 2 * turns) * amp;
          const x2 = cx + Math.sin(t * Math.PI * 2 * turns + Math.PI) * amp;
          x.globalAlpha = a * 0.7; x.beginPath(); x.moveTo(x1, y); x.lineTo(x2, y); x.stroke();
        }
        break;
      }
      case 'célula': {
        x.globalAlpha = a * 0.1; x.beginPath(); x.arc(cx, cy, r, 0, 7); x.fill();
        x.globalAlpha = a; x.lineWidth = lw(r, 0.05); x.beginPath(); x.arc(cx, cy, r, 0, 7); x.stroke();
        x.globalAlpha = a * 0.3; x.beginPath(); x.arc(cx - r * 0.12, cy - r * 0.08, r * 0.32, 0, 7); x.fill();
        x.globalAlpha = a * 0.9; x.lineWidth = lw(r, 0.035);
        x.beginPath(); x.arc(cx - r * 0.12, cy - r * 0.08, r * 0.32, 0, 7); x.stroke();
        break;
      }
      case 'persona': {
        const hr = r * 0.3, hy = cy - r * 0.52;
        x.globalAlpha = a * 0.14; x.beginPath(); x.arc(cx, hy, hr, 0, 7); x.fill();
        x.globalAlpha = a; x.lineWidth = lw(r, 0.05);
        x.beginPath(); x.arc(cx, hy, hr, 0, 7); x.stroke();
        x.globalAlpha = a * 0.14;
        x.beginPath();
        x.moveTo(cx - r * 0.66, cy + r * 0.98);
        x.quadraticCurveTo(cx - r * 0.6, cy - r * 0.04, cx, cy - r * 0.06);
        x.quadraticCurveTo(cx + r * 0.6, cy - r * 0.04, cx + r * 0.66, cy + r * 0.98);
        x.fill();
        x.globalAlpha = a; x.stroke();
        break;
      }
      case 'familia': {
        const w = r * 1.26, bh = r * 0.86, roofY = cy - r * 0.12, top = cy - r * 0.9;
        x.globalAlpha = a * 0.13; x.fillRect(cx - w / 2, roofY, w, bh);
        x.globalAlpha = a; x.lineWidth = lw(r, 0.05); x.strokeRect(cx - w / 2, roofY, w, bh);
        x.globalAlpha = a * 0.2;
        x.beginPath(); x.moveTo(cx - w / 2 - r * 0.1, roofY); x.lineTo(cx, top);
        x.lineTo(cx + w / 2 + r * 0.1, roofY); x.closePath(); x.fill();
        x.globalAlpha = a; x.stroke();
        break;
      }
      case 'barrio': {
        rounded(x, cx - r * 0.98, cy - r * 0.78, r * 1.96, r * 1.56, r * 0.24);
        x.globalAlpha = a * 0.09; x.fill();
        x.globalAlpha = a; x.lineWidth = lw(r, 0.04); x.stroke();
        // pequeños techos que insinúan casas en el borde superior
        x.globalAlpha = a * 0.85; x.lineWidth = lw(r, 0.03);
        for (let i = 0; i < 3; i++) {
          const bx = cx + (i - 1) * r * 0.5, by = cy - r * 0.78;
          x.beginPath(); x.moveTo(bx - r * 0.14, by); x.lineTo(bx, by - r * 0.16);
          x.lineTo(bx + r * 0.14, by); x.stroke();
        }
        break;
      }
      case 'ciudad': {
        // recinto con perfil de rascacielos en la parte baja
        rounded(x, cx - r * 1.02, cy - r * 0.84, r * 2.04, r * 1.68, r * 0.16);
        x.globalAlpha = a * 0.08; x.fill();
        x.globalAlpha = a; x.lineWidth = lw(r, 0.038); x.stroke();
        x.globalAlpha = a * 0.9; x.lineWidth = lw(r, 0.028);
        const base = cy + r * 0.82;
        const hs = [0.44, 0.74, 0.58, 0.92, 0.5, 0.7];
        const bw = (r * 1.9) / hs.length;
        for (let i = 0; i < hs.length; i++) {
          const bx = cx - r * 0.95 + i * bw;
          x.strokeRect(bx, base - r * hs[i], bw * 0.72, r * hs[i]);
        }
        break;
      }
      case 'nación': {
        // contorno irregular tipo continente
        const pts = 9;
        x.beginPath();
        for (let i = 0; i <= pts; i++) {
          const ang = (i / pts) * Math.PI * 2;
          const rr = r * (0.82 + 0.32 * Math.sin(i * 2.3 + 1.1) * Math.cos(i * 1.7));
          const px = cx + Math.cos(ang) * rr, py = cy + Math.sin(ang) * rr * 0.86;
          i ? x.lineTo(px, py) : x.moveTo(px, py);
        }
        x.closePath();
        x.globalAlpha = a * 0.1; x.fill();
        x.globalAlpha = a; x.lineWidth = lw(r, 0.036); x.stroke();
        break;
      }
      case 'mundo': {
        x.globalAlpha = a * 0.09; x.beginPath(); x.arc(cx, cy, r, 0, 7); x.fill();
        x.globalAlpha = a; x.lineWidth = lw(r, 0.04); x.beginPath(); x.arc(cx, cy, r, 0, 7); x.stroke();
        x.globalAlpha = a * 0.7; x.lineWidth = lw(r, 0.026);
        for (const f of [0.5, 0.82]) {
          x.beginPath(); x.ellipse(cx, cy, r * f, r, 0, 0, 7); x.stroke();
        }
        for (const yy of [-0.42, 0, 0.42]) {
          const ry = r * Math.sqrt(Math.max(0, 1 - yy * yy));
          x.beginPath(); x.ellipse(cx, cy + yy * r, ry, ry * 0.28, 0, 0, 7); x.stroke();
        }
        break;
      }
    }
    x.restore();
  }

  function rounded(x: Ctx, px: number, py: number, w: number, h: number, r: number) {
    x.beginPath();
    x.moveTo(px + r, py);
    x.arcTo(px + w, py, px + w, py + h, r);
    x.arcTo(px + w, py + h, px, py + h, r);
    x.arcTo(px, py + h, px, py, r);
    x.arcTo(px, py, px + w, py, r);
    x.closePath();
  }

  // ---- Un grupo: silueta contenedora + unidades hijas de la escala anterior --
  const UNIT_GATE = 58; // por debajo de este radio, una unidad ya no muestra su interior

  // Grupo protagonista: silueta contenedora tenue + unidades hijas agrupadas dentro.
  function group(x: Ctx, cx: number, cy: number, R: number, idx: number, a: number) {
    const s = SCALES[mod(idx, N)];
    sil(x, s.name, cx, cy, R, s.col, a * 0.7);         // contenedor tenue, marco de la escala
    if (R <= UNIT_GATE || mod(idx, N) === 0) return;   // el ADN es la base: no lleva unidades dentro
    const child = SCALES[mod(idx - 1, N)];
    const ur = R * 0.24, dist = R * 0.46, ua = smooth((R - UNIT_GATE) / 40);
    sil(x, child.name, cx, cy, ur, child.col, a * ua);                       // unidad central (el eje del zoom)
    for (let k = 0; k < 6; k++) {
      const ang = (k / 6) * Math.PI * 2 - Math.PI / 2;
      sil(x, child.name, cx + Math.cos(ang) * dist, cy + Math.sin(ang) * dist, ur * 0.9, child.col, a * ua * 0.95);
    }
  }

  function init(root: HTMLElement) {
    const cv = root.querySelector<HTMLCanvasElement>('[data-cv]')!;
    const btn = root.querySelector<HTMLButtonElement>('[data-pause]')!;
    const measure = () =>
      ctxOf(cv, Math.max(H_MIN, Math.round(cv.getBoundingClientRect().height) || H_MIN));
    let g = measure();

    function ladder(x: Ctx, w: number, h: number, active: number, big: boolean) {
      const y = h - (big ? 30 : 22);
      const x0 = 22, x1 = w - 22, step = (x1 - x0) / (N - 1);
      x.save();
      x.strokeStyle = 'rgba(255,255,255,0.12)'; x.lineWidth = 1;
      x.beginPath(); x.moveTo(x0, y); x.lineTo(x1, y); x.stroke();
      x.font = `${big ? 9 : 7}px "JetBrains Mono", monospace`;
      x.textAlign = 'center';
      for (let i = 0; i < N; i++) {
        const px = x0 + step * i, on = i === active;
        x.globalAlpha = on ? 1 : 0.5;
        x.fillStyle = on ? SCALES[i].col : MUTED;
        x.beginPath(); x.arc(px, y, on ? 4 : 2, 0, 7); x.fill();
        if (on || big) {
          x.globalAlpha = on ? 1 : 0.42;
          x.fillText(SCALES[i].name.toUpperCase(), px, y - (big ? 12 : 9));
        }
      }
      x.restore();
      x.textAlign = 'left';
    }

    function scene(elapsed: number) {
      const { x, w, h } = g;
      x.clearRect(0, 0, w, h);
      const m = Math.min(w, h), fill = m * 0.24;
      const big = h >= 420;

      const depth = Math.floor(elapsed / MS_PER_LEVEL);
      const frac = (elapsed % MS_PER_LEVEL) / MS_PER_LEVEL;
      const idx = mod(depth, N);
      const cx = w / 2, cy = h / 2 - (big ? 8 : 4);

      const isTop = idx === N - 1; // mundo: cima del recorrido, sin grupo mayor
      // Cada nivel: primero se detiene mostrando sus unidades agrupadas (dwell),
      // luego se aleja hasta volverse una pieza del grupo mayor (zoom).
      const DWELL = 0.46;
      const zf = frac <= DWELL ? 0 : (frac - DWELL) / (1 - DWELL);
      const rHero = fill * Math.pow(RATIO, -zf);

      // contorno del grupo mayor apareciendo alrededor: la escala siguiente que contendrá a esta
      if (!isTop) {
        const parent = SCALES[mod(depth + 1, N)];
        sil(x, parent.name, cx, cy, rHero * RATIO, parent.col, smooth(zf) * 0.6);
      }
      // el grupo actual, con sus unidades agrupadas, encogiéndose hacia el grupo mayor
      const aHero = 1 - smooth((zf - 0.82) / 0.18) * 0.5;
      group(x, cx, cy, rHero, depth, aHero);

      // reinicio limpio desde el ADN al terminar el mundo
      let fade = 0;
      if (isTop) fade = smooth((zf - 0.5) / 0.5);
      if (idx === 0) fade = 1 - smooth(frac / 0.22);
      if (fade > 0) { x.save(); x.globalAlpha = fade; x.fillStyle = BG; x.fillRect(0, 0, w, h); x.restore(); }

      // etiqueta de la escala actual (crossfade en el salto de nivel)
      const la = clamp01(Math.min(frac / 0.08, (1 - frac) / 0.08));
      x.font = `${big ? 11 : 9}px "JetBrains Mono", monospace`;
      x.globalAlpha = 0.75; x.fillStyle = MUTED;
      x.fillText('E S C A L A', 22, big ? 30 : 24);
      x.font = `700 ${big ? 22 : 15}px "JetBrains Mono", monospace`;
      x.globalAlpha = la * (1 - fade); x.fillStyle = SCALES[idx].col;
      x.fillText(SCALES[idx].name.toUpperCase(), 22, big ? 58 : 46);
      x.globalAlpha = 1;

      ladder(x, w, h, idx, big);
    }

    // prefers-reduced-motion: una escena estática representativa (barrio dentro de ciudad)
    function staticScene() {
      const { x, w, h } = g;
      x.clearRect(0, 0, w, h);
      const m = Math.min(w, h), big = h >= 420;
      const cx = w / 2, cy = h / 2 - (big ? 8 : 4);
      sil(x, SCALES[5].name, cx, cy, m * 0.24 * RATIO, SCALES[5].col, 0.5); // ciudad, contorno mayor
      group(x, cx, cy, m * 0.24, 4, 1);                                     // barrio con sus casas
      x.font = `${big ? 11 : 9}px "JetBrains Mono", monospace`;
      x.globalAlpha = 0.75; x.fillStyle = MUTED; x.fillText('E S C A L A', 22, big ? 30 : 24);
      x.font = `700 ${big ? 22 : 15}px "JetBrains Mono", monospace`;
      x.globalAlpha = 1; x.fillStyle = SCALES[4].col; x.fillText('BARRIO', 22, big ? 58 : 46);
      ladder(x, w, h, 4, big);
    }

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      btn.style.display = 'none';
      staticScene();
      window.addEventListener('resize', () => { g = measure(); staticScene(); });
      return;
    }

    let elapsed = 0, last = performance.now(), raf = 0, running = true;
    function tick(now: number) {
      elapsed += Math.min(now - last, 60);
      last = now;
      scene(elapsed);
      raf = requestAnimationFrame(tick);
    }
    btn.onclick = () => {
      running = !running;
      btn.textContent = running ? '⏸ Pausar' : '▶ Reanudar';
      if (running) { last = performance.now(); raf = requestAnimationFrame(tick); }
      else cancelAnimationFrame(raf);
    };
    window.addEventListener('resize', () => { g = measure(); if (!running) scene(elapsed); });
    raf = requestAnimationFrame(tick);
  }
  document.querySelectorAll<HTMLElement>('.czoom').forEach(init);
</script>

<style>
  .czoom { padding: 1rem 1.2rem 0.8rem; margin-block: 2.5rem; }
  .czoom-head { display: flex; justify-content: space-between; align-items: baseline; gap: 1rem; flex-wrap: wrap; margin-bottom: 0.9rem; }
  .czoom-title { color: var(--orange-bright); font-size: 0.78rem; letter-spacing: 0.3em; text-transform: uppercase; }
  .czoom-btn { background: var(--bg-panel-2); color: var(--text); border: 1px solid var(--line); padding: 0.3rem 0.6rem; font-family: var(--font-mono); font-size: 0.65rem; cursor: pointer; }
  .czoom-btn:hover { border-color: var(--orange); }
  .czoom canvas { display: block; width: 100%; height: 340px; }
  .czoom-cap { font-size: 0.74rem; color: var(--muted); margin-top: 0.7rem; }
  .czoom-foot { margin-top: 0.7rem; padding-top: 0.5rem; border-top: 1px dashed var(--line); font-size: 0.6rem; letter-spacing: 0.28em; color: var(--muted); }
  /* Tratamiento hero: casi página completa en escritorio. */
  @media (min-width: 900px) {
    .czoom {
      min-height: 88vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 1.4rem 2rem 1rem;
    }
    .czoom canvas { height: clamp(440px, 64vh, 880px); }
    .czoom-title { font-size: 0.9rem; }
    .czoom-btn { font-size: 0.72rem; padding: 0.4rem 0.8rem; }
    .czoom-cap { font-size: 0.82rem; }
    .czoom-foot { font-size: 0.66rem; }
  }
</style>
