---
/** Respiro visual: mini ciclo ambiental de 5 puntos con un punto de luz orbitando. Sin interacción. */
interface Props { label?: string }
const { label } = Astro.props;
---

<div class="lmini">
  <canvas data-cv height="70" aria-hidden="true"></canvas>
  {label && <div class="lmini-label">{label}</div>}
</div>

<script>
  function init(root: HTMLElement) {
    const cv = root.querySelector<HTMLCanvasElement>('[data-cv]')!;
    const ctx = cv.getContext('2d')!;
    const COLS = ['#33b7db', '#ffcc33', '#ed8d4c', '#765898', '#ff5555'];
    const N = COLS.length, H = 70, PERIOD = 6000;
    let w = 0;

    function size() {
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      w = cv.clientWidth || 220;
      cv.width = w * dpr;
      cv.height = H * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }

    const ang = (i: number) => -Math.PI / 2 + (i / N) * 2 * Math.PI;

    function draw(t: number) {
      ctx.clearRect(0, 0, w, H);
      const cx = w / 2, cy = H / 2, R = 24;

      ctx.beginPath();
      ctx.arc(cx, cy, R, 0, 2 * Math.PI);
      ctx.strokeStyle = 'rgba(255,255,255,0.07)';
      ctx.lineWidth = 1;
      ctx.stroke();

      for (let i = 0; i < N; i++) {
        ctx.beginPath();
        ctx.arc(cx + R * Math.cos(ang(i)), cy + R * Math.sin(ang(i)), 3, 0, 2 * Math.PI);
        ctx.fillStyle = COLS[i];
        ctx.fill();
      }

      if (t < 0) return;
      const a = -Math.PI / 2 + (t % PERIOD) / PERIOD * 2 * Math.PI;
      for (let k = 18; k >= 1; k--) {
        const aa = a - k * 0.085;
        ctx.beginPath();
        ctx.arc(cx + R * Math.cos(aa), cy + R * Math.sin(aa), 1.4, 0, 2 * Math.PI);
        ctx.fillStyle = `rgba(255,255,255,${(0.3 * (1 - k / 19)).toFixed(3)})`;
        ctx.fill();
      }
      ctx.beginPath();
      ctx.arc(cx + R * Math.cos(a), cy + R * Math.sin(a), 2.4, 0, 2 * Math.PI);
      ctx.fillStyle = '#fff';
      ctx.shadowColor = 'rgba(255,255,255,0.7)';
      ctx.shadowBlur = 6;
      ctx.fill();
      ctx.shadowBlur = 0;
    }

    const still = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    function frame(t: number) { draw(t); requestAnimationFrame(frame); }
    size();
    if (still) draw(-1);
    else requestAnimationFrame(frame);
    window.addEventListener('resize', () => { size(); if (still) draw(-1); });
  }
  document.querySelectorAll<HTMLElement>('.lmini').forEach(init);
</script>

<style>
  .lmini {
    margin-block: 2rem;
    min-height: 90px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
  }
  .lmini canvas {
    display: block;
    width: 100%;
    max-width: 220px;
    height: 70px;
  }
  .lmini-label {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    color: var(--muted);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-align: center;
  }
</style>
