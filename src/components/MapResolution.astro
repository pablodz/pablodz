---
/**
 * Paso 10 · Resolución del mapa + control multiescala (gobernanza policéntrica).
 *
 * Dos ejes accionables:
 *   1) RESOLUCIÓN (slider): cuántas escalas alcanza a "ver" el mapa. A baja
 *      resolución el mundo cabe en un bloque (solo el planeta es legible); al
 *      subir aparecen los países (≥34) y luego los barrios (≥67).
 *   2) CONTROL POR ESCALA (toggles: barrio / país / planeta): enciende el freno
 *      de cada escala. Pero un control SOLO surte efecto si esa escala es
 *      legible con la resolución actual: no se puede gobernar lo que no se ve.
 *
 * Para cada escala se corre el motor real (simulate) y se muestra su
 * CONCENTRACIÓN G. Una escala con control efectivo estabiliza en G baja; sin
 * freno (apagada o fuera de foco) deriva a G alta, y además "fuga"
 * concentración hacia las demás. Moraleja: fijar el mapa/control en UNA escala
 * deja las otras sin freno; solo el control multiescala las estabiliza todas.
 *
 * Constantes de G calibradas numéricamente (script en scratchpad):
 *   todo apagado          -> ~82% en las tres (nadie frena)
 *   una sola escala        -> ~52% en esa, ~82% en el resto (fuga)
 *   las tres controladas   -> ~31-36% y estable (policéntrico)
 */
---

<div class="mapr panel">
  <div class="mapr-head">
    <span class="mapr-title">◢ RESOLUCIÓN DEL MAPA · CONTROL MULTIESCALA</span>
    <span class="mapr-phase" data-st>···</span>
  </div>
  <div class="mapr-grid">
    <div><canvas data-c></canvas></div>
    <div class="mapr-ctrl">
      <label class="mapr-lab">Resolución del mapa (qué escalas se ven) <b data-v>baja</b></label>
      <input type="range" data-s min="0" max="100" value="18" />
      <div class="mapr-auto" data-auto>modo automático · mueve el slider para tomar el control</div>

      <div class="mapr-sub">Control por escala (enciéndelo por nivel)</div>
      <div class="mapr-toggles">
        <button data-t="barrio">Barrio</button>
        <button data-t="pais">País</button>
        <button data-t="planeta">Planeta</button>
      </div>

      <div class="readout" data-ro></div>
      <p class="mapr-note">Fijar el mapa en <b>una sola escala</b> deja las demás sin freno: se concentran.
      La salida es <b>un control por cada escala</b> (policéntrico), y para gobernar una escala
      primero hay que <b>poder verla</b>.</p>
    </div>
  </div>
</div>

<script>
  import { ctxOf, simulate, BASE, COL, type Params } from '../lib/machine';

  // barrio ⊂ país ⊂ planeta. th = resolución mínima para "ver" (y gobernar) la escala.
  const SCALES = [
    { key: 'barrio',  name: 'Barrio',  z: 0.62, th: 67 },
    { key: 'pais',    name: 'País',    z: 0.70, th: 34 },
    { key: 'planeta', name: 'Planeta', z: 0.78, th: 0  },
  ] as const;

  const UP = 16000, HOLD = 2600; // respiración del modo ambiente
  const ease = (t: number) => 0.5 - 0.5 * Math.cos(Math.PI * t);
  const ss = (a: number, b: number, v: number) => {
    const t = Math.min(1, Math.max(0, (v - a) / (b - a)));
    return t * t * (3 - 2 * t);
  };

  // Color por concentración G: verde (bajo) → amarillo → naranja → rojo (alto).
  const STOPS: [number, number[]][] = [
    [0.20, [82, 208, 83]], [0.42, [255, 204, 51]],
    [0.58, [237, 141, 76]], [0.82, [255, 52, 44]],
  ];
  function gColor(G: number, a = 1): string {
    let c = STOPS[0][1];
    if (G >= STOPS[STOPS.length - 1][0]) c = STOPS[STOPS.length - 1][1];
    else for (let i = 0; i < STOPS.length - 1; i++) {
      const [g0, c0] = STOPS[i], [g1, c1] = STOPS[i + 1];
      if (G >= g0 && G < g1) {
        const t = (G - g0) / (g1 - g0);
        c = c0.map((v, k) => Math.round(v + (c1[k] - v) * t));
        break;
      }
    }
    return `rgba(${c[0]},${c[1]},${c[2]},${a})`;
  }

  function init(root: HTMLElement) {
    const cv = root.querySelector<HTMLCanvasElement>('[data-c]')!;
    const sl = root.querySelector<HTMLInputElement>('[data-s]')!;
    const lv = root.querySelector<HTMLElement>('[data-v]')!;
    const st = root.querySelector<HTMLElement>('[data-st]')!;
    const ro = root.querySelector<HTMLElement>('[data-ro]')!;
    const auto = root.querySelector<HTMLElement>('[data-auto]')!;
    const btns = SCALES.map((s) => root.querySelector<HTMLButtonElement>(`[data-t="${s.key}"]`)!);
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Geometría normalizada: 3 países alrededor del centro, 4 barrios por país.
    const paisPos = [0, 1, 2].map((i) => {
      const a = -Math.PI / 2 + i * 2 * Math.PI / 3;
      return { x: 0.5 + 0.2 * Math.cos(a), y: 0.5 + 0.2 * Math.sin(a) };
    });
    const barrioPos = paisPos.flatMap((p) =>
      [0, 1, 2, 3].map((k) => {
        const a = k / 4 * 2 * Math.PI + 0.6;
        return { x: p.x + 0.055 * Math.cos(a), y: p.y + 0.055 * Math.sin(a) };
      }));

    const measure = () => ctxOf(cv, Math.max(260, Math.round(cv.getBoundingClientRect().height) || 260));
    let g = measure();

    const toggle: Record<string, boolean> = { barrio: false, pais: false, planeta: false };
    let res = +sl.value, resT = res;
    const G = [0.82, 0.82, 0.82];  // valor mostrado (persigue objetivo)
    const GT = [0.82, 0.82, 0.82]; // objetivo calculado por el motor
    const pulses: { i: number; t0: number }[] = [];
    let ambient = !reduced, ambT = 3000;
    let lastLeg = '', lastLab = '';

    /** Control efectivo = encendido Y legible con la resolución actual. */
    const effective = (i: number) => toggle[SCALES[i].key] && res >= SCALES[i].th;

    /** Corre el motor por escala; devuelve G de equilibrio (cola de la simulación). */
    function computeG(): number[] {
      const eff = SCALES.map((_, i) => effective(i));
      const unc = eff.filter((x) => !x).length;
      return SCALES.map((s, i) => {
        const other = unc - (eff[i] ? 0 : 1); // otras escalas sin freno → fuga hacia aquí
        const P: Params = {
          ...BASE, r0: 0.5, b: 2.4, gamma: 0.45, lam: 1.4,
          psi: 2.0, omega: 1.6, kc: 1.5, eta: 0.03, zeta: s.z, tau: 0.02,
        };
        if (eff[i]) { P.tau += 0.55; P.zeta *= 0.45; } // freno de la escala
        P.zeta += 0.16 * other;
        P.tau = Math.max(0.004, P.tau - 0.02 * other);
        const d = simulate(P, 2600, 0.03);
        const tail = d.slice(Math.floor(d.length * 0.75));
        return tail.reduce((a, z) => a + z[2], 0) / tail.length;
      });
    }

    /** Recalcula objetivos de G; opcionalmente lanza ping en escalas que cambiaron. */
    function recompute(pulseIdx: number[] = []) {
      const next = computeG();
      for (let i = 0; i < 3; i++) GT[i] = next[i];
      if (!reduced) pulseIdx.forEach((i) => pulses.push({ i, t0: performance.now() }));
      updateUI();
    }

    /** Estado textual de los botones + lectura numérica computada por nivel. */
    function updateUI() {
      SCALES.forEach((s, i) => {
        const b = btns[i], legible = res >= s.th, on = toggle[s.key];
        b.classList.toggle('on', on && legible);
        b.classList.toggle('pending', on && !legible);
        b.textContent = s.name + (on ? (legible ? ' ·on' : ' ·fuera de foco') : '');
      });

      const effCount = SCALES.filter((_, i) => effective(i)).length;
      const uncCount = 3 - effCount;
      const lines = SCALES.map((s, i) => {
        const eff = effective(i), legible = res >= s.th, pct = Math.round(GT[i] * 100);
        const tag = !legible ? 'fuera de foco' : eff ? 'con freno' : 'sin freno';
        return `<span class="rl"><i style="background:${gColor(GT[i])}"></i>`
          + `<b>${s.name}</b> concentración <b style="color:${gColor(GT[i])}">${pct}%</b> · ${tag}</span>`;
      }).join('');

      let lab: string, c: string, msg: string;
      if (effCount === 3) {
        lab = 'GOBERNANZA MULTIESCALA'; c = COL.green;
        msg = 'Cada escala tiene su propio freno y se ve en el mapa → <b>las tres estables</b>. Esto es policéntrico.';
      } else if (effCount === 0) {
        lab = 'MAPA SIN CONTROL'; c = COL.red;
        msg = 'Ninguna escala tiene freno → <b>todo se concentra</b>. Una idea de escala única no alcanza.';
      } else {
        lab = 'CONTROL EN UNA ESCALA'; c = COL.orange;
        msg = `Frenas <b>${effCount}</b> de 3, pero <b>${uncCount}</b> quedan sin freno y fugan concentración `
          + 'hacia el resto → ni la escala frenada logra estabilizarse del todo.';
      }
      if (lab !== lastLab) { lastLab = lab; st.textContent = lab; st.style.color = c; }
      ro.innerHTML = `<div class="rlist">${lines}</div><div class="rmsg" style="border-color:${c}">${msg}</div>`;
    }

    /** Anillo con desenfoque simulado: fuera de foco jitterea; enfocado, nítido. */
    function ring(cx: number, cy: number, r: number, col: string, lw: number, a: number, f: number, now: number, fill = false) {
      const { x } = g;
      if (a <= 0.01 || r <= 0.5) return;
      if (reduced || f > 0.96) {
        x.globalAlpha = a; x.strokeStyle = col; x.lineWidth = lw;
        x.beginPath(); x.arc(cx, cy, r, 0, 7); x.stroke();
        if (fill) { x.globalAlpha = a * 0.18; x.fillStyle = col; x.fill(); }
      } else {
        const j = (1 - f) * 6 + 1;
        x.shadowColor = col; x.shadowBlur = (1 - f) * 9;
        x.strokeStyle = col; x.lineWidth = lw;
        for (let i = 0; i < 3; i++) {
          const ph = now * 0.0011 + i * 2.09 + r * 0.13;
          x.globalAlpha = a * (0.14 + 0.5 * f);
          x.beginPath();
          x.arc(cx + Math.cos(ph) * j, cy + Math.sin(ph * 1.37) * j, Math.max(1, r + Math.sin(ph * 0.7) * j * 0.5), 0, 7);
          x.stroke();
        }
        x.shadowBlur = 0;
      }
      x.globalAlpha = 1;
    }

    function draw(now: number) {
      const { x, w, h } = g;
      x.clearRect(0, 0, w, h);
      const cx = w / 2, cy = h / 2, S = Math.min(w, h);
      const X = (u: number) => cx + (u - 0.5) * S, Y = (v: number) => cy + (v - 0.5) * S;

      // Foco por escala: rampa suave alrededor del umbral (planeta siempre nítido).
      const foc = SCALES.map((s) => (s.th <= 0 ? 1 : (reduced ? (res >= s.th ? 1 : 0) : ss(s.th - 9, s.th + 4, res))));

      // Planeta (contorno del todo).
      ring(cx, cy, S * 0.44, gColor(G[2]), 2.2, 0.85, foc[2], now, true);
      // Países.
      paisPos.forEach((p) => ring(X(p.x), Y(p.y), S * 0.11, gColor(G[1]), 1.6, 0.85 * (0.35 + 0.65 * foc[1]), foc[1], now, true));
      // Barrios (puntos).
      barrioPos.forEach((p, i) => {
        const f = foc[0];
        if (f <= 0.02) return;
        const bx = X(p.x), by = Y(p.y);
        if (!reduced && f < 0.9) {
          const j = (1 - f) * 5;
          const ph = now * 0.0012 + i * 1.6;
          x.globalAlpha = 0.5 * f; x.fillStyle = gColor(G[0]);
          x.beginPath(); x.arc(bx + Math.cos(ph) * j, by + Math.sin(ph * 1.3) * j, S * 0.02, 0, 7); x.fill();
        } else {
          x.globalAlpha = 0.9; x.fillStyle = gColor(G[0]);
          x.beginPath(); x.arc(bx, by, S * 0.02, 0, 7); x.fill();
        }
      });
      x.globalAlpha = 1;

      // Pings de radar sobre la escala que acaba de cambiar.
      for (let k = pulses.length - 1; k >= 0; k--) {
        const p = pulses[k], age = (now - p.t0) / 950;
        if (age >= 1) { pulses.splice(k, 1); continue; }
        const e = 1 - Math.pow(1 - age, 3);
        x.strokeStyle = gColor(GT[p.i]); x.lineWidth = 1.6; x.globalAlpha = (1 - age) * 0.9;
        if (p.i === 2) { x.beginPath(); x.arc(cx, cy, Math.max(1, S * 0.44 * e), 0, 7); x.stroke(); }
        else if (p.i === 1) paisPos.forEach((q) => { x.beginPath(); x.arc(X(q.x), Y(q.y), S * 0.11 * (0.25 + 1.3 * e), 0, 7); x.stroke(); });
        else barrioPos.forEach((q) => { x.beginPath(); x.arc(X(q.x), Y(q.y), S * 0.02 * (0.3 + 3 * e), 0, 7); x.stroke(); });
        x.globalAlpha = 1;
      }

      // Viñeta de profundidad de campo.
      const grd = x.createRadialGradient(cx, cy, S * 0.22, cx, cy, S * 0.62);
      grd.addColorStop(0, 'rgba(0,0,0,0)');
      grd.addColorStop(1, 'rgba(4,7,9,0.34)');
      x.fillStyle = grd; x.fillRect(0, 0, w, h);

      // Etiquetas por escala: % de concentración cuando está en foco; "??" cuando no.
      x.font = '10px "JetBrains Mono", monospace';
      const label = (px: number, py: number, i: number, al: CanvasTextAlign) => {
        x.textAlign = al; const f = foc[i];
        x.globalAlpha = 0.55 + 0.45 * f; x.fillStyle = f > 0.25 ? gColor(GT[i]) : COL.muted;
        x.fillText(`${SCALES[i].name} ${f > 0.25 ? Math.round(GT[i] * 100) + '%' : '·· ??'}`, px, py);
        x.globalAlpha = 1;
      };
      label(cx, 16, 2, 'center');
      label(X(paisPos[0].x), Y(paisPos[0].y) - S * 0.13, 1, 'center');
      label(cx, h - 12, 0, 'center');
      x.textAlign = 'left';

      // Visor de lente: esquinas + lectura de foco.
      const focv = ss(0, 100, res), inset = 22 - 8 * focv, bl = 10 + 6 * focv;
      x.strokeStyle = COL.orange; x.lineWidth = 1.2; x.globalAlpha = 0.22 + 0.5 * focv;
      ([[1, 1], [-1, 1], [1, -1], [-1, -1]] as const).forEach(([sx, sy]) => {
        const bx = sx > 0 ? inset : w - inset, by = sy > 0 ? inset : h - inset;
        x.beginPath(); x.moveTo(bx, by + sy * bl); x.lineTo(bx, by); x.lineTo(bx + sx * bl, by); x.stroke();
      });
      x.globalAlpha = 0.75; x.font = '9px "JetBrains Mono", monospace'; x.fillStyle = COL.orange;
      x.fillText('FOCO ' + Math.round(res) + '%', inset, h - inset + 13);
      x.globalAlpha = 1;
    }

    // Nivel textual de la resolución.
    function setLevelWord() {
      const nl = res < 34 ? 'baja · solo el planeta' : res < 67 ? 'media · aparecen países' : 'alta · aparecen barrios';
      lv.textContent = nl;
    }

    // Detecta cambios en el conjunto de escalas legibles (crucen de umbrales).
    const legKey = () => SCALES.map((s) => (res >= s.th ? 1 : 0)).join('');

    function syncLegibility() {
      const k = legKey();
      if (k !== lastLeg) {
        const prev = lastLeg;
        lastLeg = k;
        const changed = SCALES.map((_, i) => i).filter((i) =>
          prev !== '' && k[i] !== prev[i] && toggle[SCALES[i].key]);
        recompute(changed);
      }
    }

    // ── prefers-reduced-motion: sin rAF, se dibuja en cada cambio ──
    if (reduced) {
      auto.style.display = 'none';
      const redraw = () => { res = resT = +sl.value; setLevelWord(); lastLeg = legKey(); recompute(); draw(performance.now()); };
      sl.addEventListener('input', redraw);
      btns.forEach((b, i) => (b.onclick = () => { const k = SCALES[i].key; toggle[k] = !toggle[k]; redraw(); }));
      redraw();
      window.addEventListener('resize', () => { g = measure(); draw(performance.now()); });
      return;
    }

    // ── rAF único: res y G persiguen sus objetivos; se apaga al quedar quieto ──
    let raf = 0, last = 0;
    const animating = () => Math.abs(res - resT) > 0.05 || G.some((v, i) => Math.abs(v - GT[i]) > 0.002);

    function frame(now: number) {
      const dt = Math.min(now - last, 100); last = now;
      if (ambient) {
        ambT += dt;
        const c = ambT % (2 * (UP + HOLD));
        resT = c < UP ? 6 + 90 * ease(c / UP)
          : c < UP + HOLD ? 96
          : c < UP + HOLD + UP ? 96 - 90 * ease((c - UP - HOLD) / UP)
          : 6;
        sl.value = String(Math.round(resT));
      }
      res += (resT - res) * Math.min(1, dt * 0.005);
      if (Math.abs(resT - res) < 0.05) res = resT;
      setLevelWord();
      syncLegibility();
      for (let i = 0; i < 3; i++) G[i] += (GT[i] - G[i]) * Math.min(1, dt * 0.004);
      draw(now);
      if (ambient || pulses.length || animating()) raf = requestAnimationFrame(frame);
      else raf = 0;
    }
    const kick = () => { if (!raf) { last = performance.now(); raf = requestAnimationFrame(frame); } };
    const takeControl = () => { if (ambient) { ambient = false; auto.classList.add('off'); } resT = +sl.value; kick(); };

    sl.addEventListener('pointerdown', takeControl);
    sl.addEventListener('input', takeControl);
    btns.forEach((b, i) => (b.onclick = () => {
      if (ambient) { ambient = false; auto.classList.add('off'); }
      const k = SCALES[i].key; toggle[k] = !toggle[k];
      recompute(res >= SCALES[i].th ? [i] : []);
      kick();
    }));
    window.addEventListener('resize', () => { g = measure(); kick(); });

    lastLeg = legKey();
    recompute();
    kick();
  }
  document.querySelectorAll<HTMLElement>('.mapr').forEach(init);
</script>

<style>
  .mapr { padding: 1rem 1.2rem; margin-block: 2.5rem; }
  .mapr-head { display: flex; justify-content: space-between; align-items: baseline; gap: 1rem; flex-wrap: wrap; margin-bottom: 0.9rem; }
  .mapr-title { color: var(--orange-bright); font-size: 0.72rem; letter-spacing: 0.24em; text-transform: uppercase; }
  .mapr-phase { font-size: 0.72rem; letter-spacing: 0.16em; text-transform: uppercase; }
  .mapr-grid { display: grid; grid-template-columns: 1.3fr 1fr; gap: 1.4rem; align-items: start; }
  @media (max-width: 720px) { .mapr-grid { grid-template-columns: 1fr; } }
  .mapr-grid canvas { display: block; width: 100%; height: 260px; }
  @media (min-width: 900px) { .mapr-grid canvas { height: clamp(260px, 38vh, 440px); } }
  .mapr-ctrl { display: flex; flex-direction: column; gap: 0.6rem; }
  .mapr-lab { font-size: 0.72rem; color: var(--muted); }
  .mapr-lab b { color: var(--blue); }
  .mapr input { width: 100%; accent-color: var(--orange); }
  .mapr-auto { font-size: 0.62rem; letter-spacing: 0.08em; color: var(--muted); opacity: 0.8; transition: opacity 0.5s; }
  .mapr-auto.off { opacity: 0; }
  .mapr-sub { font-size: 0.62rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); margin-top: 0.3rem; }
  .mapr-toggles { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.4rem; }
  .mapr-toggles button { background: var(--bg-panel-2); color: var(--text); border: 1px solid var(--line); padding: 0.5rem 0.4rem; font-family: var(--font-mono); font-size: 0.66rem; cursor: pointer; transition: background 0.2s, border-color 0.2s, color 0.2s; }
  .mapr-toggles button:hover { border-color: var(--orange); }
  .mapr-toggles button.on { background: var(--orange); color: #000; font-weight: 700; border-color: var(--orange); }
  .mapr-toggles button.pending { border-color: var(--yellow); color: var(--yellow); border-style: dashed; }
  .readout { font-size: 0.74rem; color: var(--muted); }
  .readout :global(.rlist) { display: flex; flex-direction: column; gap: 0.25rem; background: var(--bg-deep); border: 1px solid var(--line); padding: 0.55rem 0.7rem; }
  .readout :global(.rl) { display: flex; align-items: center; gap: 0.45rem; font-size: 0.72rem; }
  .readout :global(.rl i) { width: 9px; height: 9px; border-radius: 50%; flex: none; }
  .readout :global(.rl b) { color: var(--text); font-weight: 600; }
  .readout :global(.rmsg) { margin-top: 0.4rem; font-size: 0.73rem; background: var(--bg-deep); border-left: 2px solid var(--orange); padding: 0.5rem 0.7rem; }
  .readout :global(.rmsg b) { color: var(--text); }
  .mapr-note { font-size: 0.72rem; color: var(--muted); }
  .mapr-note b { color: var(--text); }
</style>
