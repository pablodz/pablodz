---
/**
 * Paso 4 · La pirámide de poder, ejemplificada: cinco jerarquías reales
 * (un imperio antiguo, el feudalismo, una democracia rica, internet y el
 * campo) con % de personas vs % de poder/riqueza por capa.
 *
 * Ahora, además de comparar datos históricos, deja ver la pirámide FORMARSE
 * en el tiempo: un slider de concentración (G objetivo) y un botón "▶ correr"
 * que integra el motor (simulate) y morfea las barras de plano a pirámide.
 */
---

<figure class="ppyr panel">
  <figcaption class="ppyr-head">
    <span class="ppyr-title">◢ LA MISMA PIRÁMIDE, EN CINCO MUNDOS DISTINTOS</span>
    <span class="ppyr-phase" data-phase>···</span>
  </figcaption>
  <div class="ppyr-tabs" data-tabs></div>
  <div class="ppyr-rows" data-rows></div>
  <div class="ppyr-ctrl">
    <label>Concentración / acaparamiento (objetivo) <b data-l>100%</b>
      <input type="range" data-s min="0" max="100" step="1" value="100" /></label>
    <div class="ppyr-btns">
      <button data-run class="prim">▶ Correr</button>
      <button data-reset>Aplanar</button>
    </div>
    <div class="ppyr-reading" data-read></div>
  </div>
  <div class="readout" data-note></div>
  <div class="ppyr-legend">
    <span><i class="lg-people"></i>qué % de la gente es esa capa</span>
    <span><i class="lg-power"></i>qué % del poder / riqueza captura</span>
  </div>
  <div class="ppyr-foot">CINCO SISTEMAS SIN NADA EN COMÚN · Y LA MISMA FORMA</div>
</figure>

<script>
  import { BASE, simulate, COL } from '../lib/machine';

  interface Layer { name: string; pp: number; pl: string; wp: number; wl: string }
  interface World { k: string; tab: string; note: string; layers: Layer[] }

  const WORLDS: World[] = [
    {
      k: 'usa', tab: 'EE.UU. hoy',
      note: '<b>Riqueza de los hogares, EE.UU. 2023</b> (Reserva Federal). La democracia más rica del planeta, con mercados formalmente justos, produce esta forma sola. La mitad del país entera pesa menos que un punto porcentual por persona del 1%.',
      layers: [
        { name: 'El 1% más rico', pp: 1, pl: '1% de la gente', wp: 31, wl: '~31% de la riqueza' },
        { name: 'El siguiente 9%', pp: 9, pl: '9%', wp: 36, wl: '~36%' },
        { name: 'La "clase media" (40%)', pp: 40, pl: '40%', wp: 30, wl: '~30%' },
        { name: 'La mitad de abajo', pp: 50, pl: '50% de la gente', wp: 3, wl: '~3% de la riqueza' },
      ],
    },
    {
      k: 'roma', tab: 'Roma imperial',
      note: '<b>Ingreso del Imperio Romano, siglo II</b> (Scheidel & Friesen, 2009). Dos mil años antes del capitalismo, sin bolsa ni corporaciones: una élite del 1.5% capturaba tanto como el 10% siguiente, y casi el 90% vivía pegado a la subsistencia.',
      layers: [
        { name: 'Élite (senadores, équites, decuriones)', pp: 1.5, pl: '1.5% de la gente', wp: 20, wl: '~20% del ingreso' },
        { name: '"Medios" urbanos', pp: 10, pl: '10%', wp: 20, wl: '~20%' },
        { name: 'El resto (subsistencia)', pp: 88.5, pl: '88.5% de la gente', wp: 60, wl: '~60%, repartido entre casi todos' },
      ],
    },
    {
      k: 'feudal', tab: 'Feudalismo',
      note: '<b>Tierra de Inglaterra, censo Domesday de 1086.</b> Un solo hombre (el rey) poseía ~17% del país; con la Iglesia y unos ~200 barones sumaban más del 80%. Los ~2 millones de campesinos que la trabajaban, casi nada. La pirámide en su versión más desnuda.',
      layers: [
        { name: 'El rey', pp: 0.0001, pl: '1 persona', wp: 17, wl: '~17% de la tierra' },
        { name: 'La Iglesia', pp: 1, pl: '~1%', wp: 26, wl: '~26%' },
        { name: 'Barones (tenentes en jefe)', pp: 0.01, pl: '~200 personas', wp: 40, wl: '~40%' },
        { name: 'Campesinos', pp: 99, pl: '~99% de la gente', wp: 17, wl: '~17% restante' },
      ],
    },
    {
      k: 'stream', tab: 'Internet',
      note: '<b>Atención en Twitch.</b> Según la filtración de pagos de 2021, el 1% de los canales capturó más de la mitad de los ingresos, y los rastreadores independientes estiman cerca de dos tercios de las horas vistas. La forma es la misma que la feudal, con una diferencia que importa: aquí la cima rota y la entrada sigue abierta. Lo que los controles deben cuidar es que la pirámide no se congele.',
      layers: [
        { name: 'Top 1% de canales', pp: 1, pl: '1% de los canales', wp: 66, wl: '~2/3 de las horas vistas' },
        { name: 'El siguiente 9%', pp: 9, pl: '9%', wp: 25, wl: '~25%' },
        { name: 'El 90% restante', pp: 90, pl: '90% de los canales', wp: 9, wl: '~9% de la atención' },
      ],
    },
    {
      k: 'land', tab: 'Campo global',
      note: '<b>Tierra agrícola del mundo</b> (International Land Coalition, 2020): el 1% de las fincas más grandes opera ~70% de la tierra agrícola global. La concentración no es el vicio de un país o una época, sino el estado por defecto cuando nada la frena.',
      layers: [
        { name: 'El 1% de fincas más grandes', pp: 1, pl: '1% de las fincas', wp: 70, wl: '~70% de la tierra' },
        { name: 'El siguiente 9%', pp: 9, pl: '9%', wp: 15, wl: '~15%' },
        { name: 'El 90% de fincas familiares', pp: 90, pl: '90% de las fincas', wp: 15, wl: '~15% de la tierra' },
      ],
    },
  ];

  const reduceMotion =
    typeof matchMedia === 'function' && matchMedia('(prefers-reduced-motion: reduce)').matches;

  const fmt = (v: number) => (v >= 10 ? v.toFixed(0) : v >= 1 ? v.toFixed(1) : v.toFixed(2));

  // % del poder que captura el 10% de personas con más poder por cabeza.
  function topDecile(layers: Layer[], m: number): number {
    const cur = layers.map((l) => ({ pp: l.pp, pow: l.pp + (l.wp - l.pp) * m }));
    cur.sort((a, b) => b.pow / Math.max(1e-9, b.pp) - a.pow / Math.max(1e-9, a.pp));
    let people = 0,
      pow = 0;
    for (const c of cur) {
      if (people >= 10) break;
      const take = Math.min(c.pp, 10 - people);
      pow += c.pow * (take / Math.max(1e-9, c.pp));
      people += take;
    }
    return pow;
  }

  function init(root: HTMLElement) {
    const tabs = root.querySelector<HTMLElement>('[data-tabs]')!;
    const rows = root.querySelector<HTMLElement>('[data-rows]')!;
    const note = root.querySelector<HTMLElement>('[data-note]')!;
    const phase = root.querySelector<HTMLElement>('[data-phase]')!;
    const read = root.querySelector<HTMLElement>('[data-read]')!;
    const slider = root.querySelector<HTMLInputElement>('[data-s]')!;
    const sLabel = root.querySelector<HTMLElement>('[data-l]')!;
    const runBtn = root.querySelector<HTMLButtonElement>('[data-run]')!;
    const resetBtn = root.querySelector<HTMLButtonElement>('[data-reset]')!;

    let idx = 0; // mundo activo (preset / objetivo histórico)
    let bars: { powEl: HTMLElement; powLab: HTMLElement }[] = [];
    let raf = 0;

    WORLDS.forEach((wd, i) => {
      const b = document.createElement('button');
      b.textContent = wd.tab;
      b.onclick = () => selectWorld(i);
      tabs.appendChild(b);
    });

    // Construye el DOM de las capas una sola vez por mundo; guarda refs.
    function buildRows() {
      const wd = WORLDS[idx];
      rows.innerHTML = wd.layers
        .map(
          (l) => `
        <div class="lay">
          <div class="lay-name">${l.name}</div>
          <div class="lay-bars">
            <div class="bar-row"><div class="bar people" style="width:${Math.max(0.6, l.pp)}%"></div><span>${l.pl}</span></div>
            <div class="bar-row"><div class="bar power" data-pow></div><span data-powlab></span></div>
          </div>
        </div>`,
        )
        .join('');
      const powEls = rows.querySelectorAll<HTMLElement>('[data-pow]');
      const powLabs = rows.querySelectorAll<HTMLElement>('[data-powlab]');
      bars = wd.layers.map((_, i) => ({ powEl: powEls[i], powLab: powLabs[i] }));
      note.innerHTML = wd.note;
    }

    // Pinta las barras de poder para una fracción de morfeo m ∈ [0,1].
    function paint(m: number) {
      const wd = WORLDS[idx];
      wd.layers.forEach((l, i) => {
        const cur = l.pp + (l.wp - l.pp) * m;
        bars[i].powEl.style.width = Math.max(0.6, cur) + '%';
        bars[i].powLab.textContent = m >= 0.995 ? l.wl : `${fmt(cur)}% ahora`;
      });
      const top = wd.layers[0];
      const topCur = top.pp + (top.wp - top.pp) * m;
      const dec = topDecile(wd.layers, m);
      read.innerHTML = `La cima (<b>${top.name}</b>) captura <b>${fmt(topCur)}%</b> · el 10% de arriba: <b>${dec.toFixed(0)}%</b>`;

      let lab: string, col: string;
      if (dec < 22) { lab = 'Repartido · todos parecidos'; col = COL.green; }
      else if (dec < 50) { lab = 'Pirámide formándose'; col = COL.yellow; }
      else { lab = 'Pirámide marcada'; col = COL.orange; }
      phase.textContent = lab;
      phase.style.color = col;
    }

    function stopRun() {
      if (raf) cancelAnimationFrame(raf);
      raf = 0;
      rows.classList.remove('run');
      runBtn.textContent = '▶ Correr';
      runBtn.classList.remove('on');
    }

    // ▶ Correr: integra el motor y morfea de plano (m=0) al objetivo (gStar),
    // siguiendo la forma temporal real de G(t). "Acaparamiento" ↦ zeta.
    function run() {
      if (raf) { stopRun(); return; }
      const gStar = +slider.value / 100;
      if (gStar <= 0) { paint(0); return; }

      const zeta = 0.14 + gStar * 0.31; // más acaparamiento → G sube antes y más
      const traj = simulate({ ...BASE, zeta }, 300, 0.03);
      const g = traj.map((r) => r[2]);
      const g0 = g[0];
      const gmax = Math.max(...g);
      let running = 0;
      const profile = g.map((v) => {
        const n = (v - g0) / Math.max(1e-6, gmax - g0);
        running = Math.max(running, n);
        return Math.min(1, running);
      });

      if (reduceMotion) { paint(gStar); return; }

      rows.classList.add('run'); // desactiva la transición CSS mientras corre rAF
      runBtn.textContent = '⏸ Pausar';
      runBtn.classList.add('on');
      let pi = 0;
      const tick = () => {
        pi += 4;
        if (pi >= profile.length) { paint(gStar); stopRun(); return; }
        paint(gStar * profile[pi]);
        raf = requestAnimationFrame(tick);
      };
      paint(0);
      raf = requestAnimationFrame(tick);
    }

    function selectWorld(i: number) {
      stopRun();
      idx = i;
      tabs.querySelectorAll('button').forEach((b, j) => b.classList.toggle('on', j === i));
      buildRows();
      // en el siguiente frame para que la transición CSS corra desde 0
      requestAnimationFrame(() => paint(+slider.value / 100));
    }

    slider.addEventListener('input', () => {
      stopRun();
      const v = +slider.value;
      sLabel.textContent = v + '%';
      paint(v / 100);
    });

    runBtn.onclick = run;
    resetBtn.onclick = () => {
      stopRun();
      slider.value = '0';
      sLabel.textContent = '0%';
      paint(0);
    };

    selectWorld(0);
  }

  document.querySelectorAll<HTMLElement>('.ppyr').forEach(init);
</script>

<style>
  .ppyr { padding: 1rem 1.2rem 0.8rem; margin-block: 2.5rem; }
  .ppyr-head { display: flex; justify-content: space-between; align-items: baseline; gap: 1rem; flex-wrap: wrap; margin-bottom: 0.9rem; }
  .ppyr-title { color: var(--orange-bright); font-size: 0.78rem; letter-spacing: 0.3em; text-transform: uppercase; }
  .ppyr-phase { font-size: 0.72rem; letter-spacing: 0.15em; text-transform: uppercase; }
  .ppyr-tabs { display: flex; gap: 0.4rem; flex-wrap: wrap; margin-bottom: 1rem; }
  .ppyr-tabs :global(button) {
    background: var(--bg-panel-2); color: var(--text); border: 1px solid var(--line);
    padding: 0.4rem 0.7rem; font-family: var(--font-mono); font-size: 0.7rem;
    letter-spacing: 0.08em; cursor: pointer;
  }
  .ppyr-tabs :global(button:hover) { border-color: var(--orange); color: var(--orange-bright); }
  .ppyr-tabs :global(button.on) { background: var(--orange); color: #000; font-weight: 700; border-color: var(--orange); }
  .ppyr-rows { display: flex; flex-direction: column; gap: 0.9rem; }
  .ppyr-rows :global(.lay) { display: grid; grid-template-columns: minmax(11rem, 0.6fr) 1.4fr; gap: 1rem; align-items: center; }
  .ppyr-rows :global(.lay-name) { font-size: 0.74rem; color: var(--text); text-align: right; line-height: 1.4; }
  .ppyr-rows :global(.lay-bars) { display: flex; flex-direction: column; gap: 0.25rem; }
  .ppyr-rows :global(.bar-row) { display: flex; align-items: center; gap: 0.6ch; font-size: 0.68rem; color: var(--muted); }
  .ppyr-rows :global(.bar) { height: 12px; width: 0; flex: none; }
  .ppyr-rows :global(.bar.people) { background: var(--blue); }
  .ppyr-rows :global(.bar.power) { background: var(--orange); }
  .ppyr-rows :global(.bar-row span) { white-space: nowrap; }
  @media (prefers-reduced-motion: no-preference) {
    .ppyr-rows :global(.bar) { transition: width 0.6s cubic-bezier(0.2, 0.8, 0.2, 1); }
    /* mientras corre el rAF, sin transición: los frames ya animan el ancho */
    .ppyr-rows.run :global(.bar.power) { transition: none; }
  }
  .ppyr-ctrl { display: flex; flex-direction: column; gap: 0.7rem; margin-top: 1.1rem; }
  .ppyr-ctrl label { display: flex; flex-direction: column; gap: 0.25rem; font-size: 0.7rem; color: var(--muted); letter-spacing: 0.05em; }
  .ppyr-ctrl label b { color: var(--blue); }
  .ppyr-ctrl input[type='range'] { width: 100%; accent-color: var(--orange); }
  .ppyr-btns { display: flex; gap: 0.4rem; }
  .ppyr button { background: var(--bg-panel-2); color: var(--text); border: 1px solid var(--line); padding: 0.45rem 0.7rem; font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.08em; cursor: pointer; }
  .ppyr button:hover { border-color: var(--orange); color: var(--orange-bright); }
  .ppyr button.prim { background: var(--orange); color: #000; font-weight: 700; border-color: var(--orange); }
  .ppyr button.on { background: var(--yellow); color: #000; border-color: var(--yellow); }
  .ppyr-reading { font-size: 0.72rem; color: var(--muted); background: var(--bg-deep); border: 1px solid var(--line); padding: 0.6rem 0.7rem; line-height: 1.7; }
  .ppyr-reading :global(b) { color: var(--text); }
  .readout { font-size: 0.78rem; color: var(--muted); background: var(--bg-deep); border: 1px solid var(--line); padding: 0.65rem 0.8rem; margin-top: 1rem; line-height: 1.7; }
  .readout :global(b) { color: var(--text); }
  .ppyr-legend { display: flex; gap: 1.2rem; flex-wrap: wrap; font-size: 0.66rem; color: var(--muted); margin-top: 0.7rem; }
  .ppyr-legend i { width: 14px; height: 8px; display: inline-block; margin-right: 0.5ch; vertical-align: middle; }
  .lg-people { background: var(--blue); }
  .lg-power { background: var(--orange); }
  .ppyr-foot { margin-top: 0.7rem; padding-top: 0.5rem; border-top: 1px dashed var(--line); font-size: 0.6rem; letter-spacing: 0.28em; color: var(--muted); }
  @media (max-width: 700px) {
    .ppyr-rows :global(.lay) { grid-template-columns: 1fr; gap: 0.3rem; }
    .ppyr-rows :global(.lay-name) { text-align: left; color: var(--orange-bright); }
    .ppyr-rows :global(.bar-row span) { white-space: normal; }
  }
  @media (min-width: 900px) {
    .ppyr { padding: 1.6rem 1.2rem 1.3rem; }
    .ppyr-rows { gap: 1.2rem; }
    .ppyr-rows :global(.bar) { height: 20px; }
    .ppyr-rows :global(.lay-name) { font-size: 0.85rem; }
    .ppyr-rows :global(.bar-row) { font-size: 0.78rem; }
  }
</style>
