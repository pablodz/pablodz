---
/** Paso 8 · Células anidadas (SVG estático) + escalera de escaseces (interactiva). */
const labels = ['civilización', 'Estado', 'empresa', 'organismo', 'célula', 'genes'];
const cols = ['#ffcc33', '#f0abfc', '#a78bfa', '#818cf8', '#33b7db', '#6ee7ff'];
const cx = 210, cy = 210;
let nest = '';
for (let i = 0; i < 6; i++) {
  const R = 200 - i * 30;
  nest += `<circle cx="${cx}" cy="${cy}" r="${R}" fill="none" stroke="${cols[i]}" stroke-width="1.4" opacity="${0.35 + 0.09 * i}"/>`;
  nest += `<text x="${cx}" y="${cy - R + 15}" fill="${cols[i]}" font-size="11" font-family="monospace" text-anchor="middle">${labels[i]}</text>`;
}
for (let i = 0; i < 6; i++) {
  const R = 200 - i * 30;
  for (let k = 0; k < 8; k++) {
    const ang = k / 8 * 6.283 + i * 0.4;
    nest += `<circle cx="${(cx + R * Math.cos(ang)).toFixed(1)}" cy="${(cy + R * Math.sin(ang)).toFixed(1)}" r="2.5" fill="${k % 4 === 0 ? '#ed8d4c' : cols[i]}"/>`;
  }
}
const nestSvg = `<svg viewBox="0 0 420 420" style="max-width:400px;width:100%">${nest}</svg>`;
---

<div class="scales panel">
  <div class="scales-grid">
    <div class="scales-nest" set:html={nestSvg}></div>
    <div class="scales-txt">
      <p>Genes que cooperan dentro de una célula. Células dentro de un organismo. Personas dentro de una
      empresa. Empresas y clases dentro de un país. Países dentro de una civilización. En cada nivel, la misma
      máquina: cooperar hacia adentro, competir hacia afuera. Un "imperio" es, literalmente,
      <strong>un montón de células que agrandaron su "nosotros"</strong> hasta abarcar a millones.</p>
      <p>Por eso la historia parece un caos: es la <em>suma</em> de muchas máquinas girando a distintas
      velocidades. Debajo no hay una sola causa, pero sí una <em>gramática compartida</em>.</p>
    </div>
  </div>
</div>

<div class="ladder panel">
  <div class="ladder-head">
    <span class="ladder-title">◢ LA ESCALERA DE LAS ESCASECES</span>
    <span class="ladder-phase" data-phase>Piso 1 · material</span>
  </div>

  <div class="ladder-svg" data-svg></div>

  <div class="ladder-btns">
    <button data-up class="prim">✓ Resolver esta escasez → subir un piso</button>
    <button data-down>▼ Bajar un piso</button>
    <button data-reset>Volver al principio</button>
  </div>

  <div class="readout" data-info></div>

  <p class="ladder-cap">Resuelves una escasez y la pelea no muere: <b>sube un piso</b>. Abajo, escaseces
  <b class="mat">materiales</b> (la cantidad puede crecer, así que se resuelven). Arriba, bienes
  <b class="pos">posicionales</b> (estar "arriba" es relativo: no todos caben, así que <em>nunca</em> se
  vacían).</p>
</div>

<script>
  function init(root) {
    const host = root.querySelector('[data-svg]');
    const info = root.querySelector('[data-info]');
    const phase = root.querySelector('[data-phase]');
    const up = root.querySelector('[data-up]');
    const down = root.querySelector('[data-down]');
    const rs = root.querySelector('[data-reset]');

    // kind: 'mat' = material (resoluble) · 'pos' = posicional (escaso por definición)
    const rungs = [
      { n: 'Comida', s: 'sobrevivir el día', k: 'mat' },
      { n: 'Tierra', s: 'un lugar propio', k: 'mat' },
      { n: 'Dinero', s: 'seguridad y opciones', k: 'mat' },
      { n: 'Atención', s: 'que te vean', k: 'pos' },
      { n: 'Estatus', s: 'estar por encima', k: 'pos' },
      { n: 'Sentido', s: 'que todo importe', k: 'pos' },
      { n: '¿ ?', s: 'la próxima escasez', k: 'pos', ghost: true },
    ];
    const N = rungs.length;
    const C = {
      mat: '#33b7db', pos: '#a78bfa', now: '#ffcc33', nowDim: '#ed8d4c',
      done: '#52d053', line: '#4a4a55', deep: '#101014', muted: '#8f8b83', red: '#ff6b6b',
    };
    // Geometría de la escalera.
    const X0 = 60, SW = 116, SH = 56, baseY = 430;
    const cxOf = (i) => X0 + i * SW + SW / 2;
    const tyOf = (i) => baseY - i * SH;

    let cur = 0;

    function stairPath() {
      let p = `M ${X0} ${baseY}`;
      for (let i = 0; i < N; i++) {
        const ty = tyOf(i);
        p += ` L ${X0 + i * SW} ${ty} L ${X0 + (i + 1) * SW} ${ty}`;
      }
      return p + ` L ${X0 + N * SW} ${baseY} Z`;
    }

    function draw() {
      let s = '';
      // Silueta de la escalera.
      s += `<path d="${stairPath()}" fill="${C.deep}" stroke="${C.line}" stroke-width="1.4" opacity="0.9"/>`;
      // Umbral material / posicional (entre "Dinero" y "Atención").
      const thY = 265;
      s += `<line x1="24" y1="${thY}" x2="900" y2="${thY}" stroke="${C.pos}" stroke-width="1" stroke-dasharray="3 5" opacity="0.5"/>`;
      s += `<text x="28" y="${thY - 6}" fill="${C.pos}" font-size="10" font-family="monospace" opacity="0.85">▲ posicional · nunca se vacía</text>`;
      s += `<text x="28" y="${thY + 15}" fill="${C.mat}" font-size="10" font-family="monospace" opacity="0.85">▼ material · se resuelve</text>`;
      // Título.
      s += `<text x="460" y="20" fill="${C.muted}" font-size="12" font-family="monospace" text-anchor="middle">resuelves una escasez ▸ subes un piso ▸ reaparece la pelea, más arriba</text>`;
      // Flechas "sube al siguiente".
      for (let i = 0; i < N - 1; i++) {
        const rx = X0 + (i + 1) * SW;
        const my = (tyOf(i) + tyOf(i + 1)) / 2;
        const active = i === cur;
        const col = active ? C.now : C.line;
        const op = active ? 1 : 0.4;
        s += `<path d="M ${rx} ${my + 7} L ${rx} ${my - 7} M ${rx - 4} ${my - 3} L ${rx} ${my - 7} L ${rx + 4} ${my - 3}" fill="none" stroke="${col}" stroke-width="${active ? 2.2 : 1.4}" opacity="${op}"/>`;
      }
      // Nodos.
      for (let i = 0; i < N; i++) {
        const cx = cxOf(i), ty = tyOf(i);
        const rw = 100, rh = 34, rx = cx - rw / 2, ry = ty - 8 - rh;
        const rung = rungs[i];
        const base = rung.k === 'mat' ? C.mat : C.pos;
        let stroke = base, fill = C.deep, op = 1, lw = 2, textCol = base, dash = '';
        let badge = '', badgeCol = '';

        if (rung.ghost) { dash = ' stroke-dasharray="4 4"'; }

        if (i < cur) {
          // Ya pasaste por este piso.
          if (rung.k === 'mat') { stroke = C.done; textCol = C.done; op = 0.55; badge = '✓'; badgeCol = C.done; }
          else { op = 0.55; badge = '∞'; badgeCol = C.pos; }
        } else if (i === cur) {
          stroke = C.now; textCol = C.now; lw = 3.2;
          s += `<circle class="pulse" cx="${cx}" cy="${ty - 8 - rh / 2}" r="${rw / 2 + 8}" fill="none" stroke="${C.now}" stroke-width="1.2"/>`;
        } else {
          op = 0.4;
        }

        // Marco del nodo.
        s += `<rect x="${rx}" y="${ry}" width="${rw}" height="${rh}" rx="6" fill="${fill}" stroke="${stroke}" stroke-width="${lw}" opacity="${op}"${dash}/>`;
        // Nombre.
        s += `<text x="${cx}" y="${ry + 15}" fill="${textCol}" font-size="13" font-family="monospace" font-weight="700" text-anchor="middle" opacity="${op}">${rung.n}</text>`;
        // Subtítulo.
        s += `<text x="${cx}" y="${ry + 28}" fill="${C.muted}" font-size="8.5" font-family="monospace" text-anchor="middle" opacity="${op}">${rung.s}</text>`;
        // Insignia de estado (esquina).
        if (badge) s += `<text x="${rx + rw - 9}" y="${ry + 14}" fill="${badgeCol}" font-size="13" font-weight="700" text-anchor="middle">${badge}</text>`;
        // Marcador "la máquina" sobre el piso actual.
        if (i === cur) {
          const my = ry - 12;
          s += `<circle cx="${cx}" cy="${my - 4}" r="3.2" fill="${C.now}"/>`;
          s += `<path d="M ${cx} ${my} L ${cx - 5} ${my + 8} L ${cx + 5} ${my + 8} Z" fill="${C.now}"/>`;
        }
        // Zona clicable.
        s += `<rect data-i="${i}" x="${cx - SW / 2}" y="${ry - 18}" width="${SW}" height="${rh + 34}" fill="transparent" style="cursor:pointer"/>`;
      }
      // Suelo.
      s += `<text x="${X0}" y="455" fill="${C.muted}" font-size="10" font-family="monospace">piso 1 (comida) = suelo · cada peldaño, un piso más</text>`;

      host.innerHTML = `<svg viewBox="0 0 920 478" style="max-width:100%;width:100%" role="img" aria-label="Escalera de escaseces: comida, tierra, dinero, atención, estatus, sentido">${s}</svg>`;
    }

    function esc(list) { return list.map((r) => r.n).join(', '); }

    function refresh() {
      draw();
      const r = rungs[cur];
      const below = rungs.slice(0, cur);
      const resueltas = below.filter((x) => x.k === 'mat');
      const abiertas = below.filter((x) => x.k === 'pos');

      // Fase (cabecera).
      if (r.ghost) { phase.textContent = 'sin techo'; phase.style.color = C.red; }
      else if (r.k === 'mat') { phase.textContent = `Piso ${cur + 1} · material`; phase.style.color = C.mat; }
      else { phase.textContent = `Piso ${cur + 1} · posicional`; phase.style.color = C.pos; }

      // Lectura de estado.
      let html = '';
      if (r.ghost) {
        html += `<div class="ro-now">Llegaste al <b>último piso imaginable</b>… y aun así asoma <b style="color:${C.red}">otra escasez</b>.</div>`;
        html += `<p class="ro-why">La máquina no muere: solo cambia de combustible y se hace más grande. Siempre hay un piso más.</p>`;
      } else {
        html += `<div class="ro-now">Ahora peleas por <b style="color:${C.now}">${r.n}</b>: ${r.s}.</div>`;
        if (r.k === 'mat') {
          html += `<div class="ro-kind mat">MATERIAL · la cantidad puede crecer</div>`;
          html += `<p class="ro-why">Con suficiente abundancia, esta escasez <b>se resuelve para todos</b>. Pero al resolverla la pelea no se acaba: <b>salta un piso arriba</b>.</p>`;
        } else {
          html += `<div class="ro-kind pos">POSICIONAL · escaso por definición</div>`;
          html += `<p class="ro-why">Aunque sobre de todo, <b>no todos pueden estar "arriba"</b>: lo tuyo es estar por encima de otro. Este peldaño <b>nunca se vacía</b>: por eso aquí la máquina no se apaga.</p>`;
        }
      }
      // Qué quedó abajo.
      if (cur > 0) {
        let chips = '';
        if (resueltas.length) chips += resueltas.map((x) => `<span class="chip done">✓ ${x.n}</span>`).join('');
        if (abiertas.length) chips += abiertas.map((x) => `<span class="chip open">∞ ${x.n}</span>`).join('');
        html += `<div class="ro-below"><span class="ro-lbl">Abajo:</span> ${chips}</div>`;
        if (abiertas.length) html += `<div class="ro-note">Las ∞ siguen abiertas: pasaste de piso, pero esa escasez posicional nunca quedó resuelta.</div>`;
      }
      info.innerHTML = html;

      // Botones.
      const atTop = cur >= N - 1;
      up.disabled = atTop;
      up.style.opacity = atTop ? '0.4' : '1';
      up.textContent = atTop
        ? '▲ no hay techo'
        : (r.k === 'mat' ? '✓ Resolver esta escasez → subir un piso' : 'Subir un piso → (esta no se resuelve)');
      down.disabled = cur <= 0;
      down.style.opacity = cur <= 0 ? '0.4' : '1';
    }

    host.addEventListener('click', (e) => {
      const el = e.target.closest('[data-i]');
      if (el) { cur = +el.getAttribute('data-i'); refresh(); }
    });
    up.onclick = () => { if (cur < N - 1) { cur++; refresh(); } };
    down.onclick = () => { if (cur > 0) { cur--; refresh(); } };
    rs.onclick = () => { cur = 0; refresh(); };
    refresh();
  }
  document.querySelectorAll('.ladder').forEach(init);
</script>

<style>
  .scales { padding: 1rem 1.2rem; margin-block: 1.5rem; }
  .scales-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.4rem; align-items: center; }
  @media (max-width: 720px) { .scales-grid { grid-template-columns: 1fr; } }
  .scales-nest { display: grid; place-items: center; }
  .scales-txt p { font-size: 0.86rem; color: #cfccc5; }
  .scales-txt p + p { margin-top: 0.8rem; }

  .ladder { padding: 1rem 1.2rem 0.9rem; margin-block: 1.5rem; }
  .ladder-head { display: flex; justify-content: space-between; align-items: baseline; gap: 1rem; flex-wrap: wrap; margin-bottom: 0.7rem; }
  .ladder-title { color: var(--orange-bright); font-size: 0.78rem; letter-spacing: 0.28em; text-transform: uppercase; }
  .ladder-phase { font-size: 0.72rem; letter-spacing: 0.14em; font-family: var(--font-mono); }

  .ladder-svg { width: 100%; overflow-x: auto; -webkit-overflow-scrolling: touch; }
  .ladder-svg :global(svg) { display: block; width: 100%; }
  @media (max-width: 760px) {
    /* La escalera mantiene un ancho legible en mobile y se desplaza. */
    .ladder-svg :global(svg) { min-width: 660px; }
  }
  .ladder-svg :global(.pulse) { animation: ladderPulse 1.9s ease-in-out infinite; transform-origin: center; }
  @keyframes ladderPulse { 0%, 100% { opacity: 0.25; } 50% { opacity: 0.75; } }
  @media (prefers-reduced-motion: reduce) {
    .ladder-svg :global(.pulse) { animation: none; opacity: 0.55; }
  }

  .ladder-btns { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 0.85rem; }
  .ladder-btns button { background: var(--bg-panel-2); color: var(--text); border: 1px solid var(--line); padding: 0.45rem 0.7rem; font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.05em; cursor: pointer; }
  .ladder-btns button:hover:not(:disabled) { border-color: var(--orange); color: var(--orange-bright); }
  .ladder-btns button.prim { background: var(--orange); color: #000; font-weight: 700; border-color: var(--orange); }
  .ladder-btns button:disabled { cursor: default; }

  .readout { font-size: 0.78rem; color: var(--muted); background: var(--bg-deep); border: 1px solid var(--line); padding: 0.7rem 0.8rem; margin-top: 0.75rem; }
  .readout :global(b) { color: var(--text); }
  .readout :global(.ro-now) { color: var(--text); font-size: 0.86rem; }
  .readout :global(.ro-kind) { display: inline-block; font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.14em; padding: 0.15rem 0.45rem; border: 1px solid; border-radius: 3px; margin: 0.5rem 0 0.1rem; }
  .readout :global(.ro-kind.mat) { color: var(--blue); border-color: var(--blue); }
  .readout :global(.ro-kind.pos) { color: var(--purple); border-color: var(--purple); }
  .readout :global(.ro-why) { margin-top: 0.4rem; line-height: 1.5; }
  .readout :global(.ro-below) { margin-top: 0.6rem; padding-top: 0.55rem; border-top: 1px dashed var(--line); display: flex; align-items: center; gap: 0.35rem; flex-wrap: wrap; }
  .readout :global(.ro-lbl) { font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.1em; text-transform: uppercase; }
  .readout :global(.chip) { font-family: var(--font-mono); font-size: 0.66rem; padding: 0.12rem 0.4rem; border: 1px solid; border-radius: 3px; }
  .readout :global(.chip.done) { color: var(--green); border-color: var(--green); }
  .readout :global(.chip.open) { color: var(--purple); border-color: var(--purple); }
  .readout :global(.ro-note) { margin-top: 0.45rem; font-size: 0.72rem; font-style: italic; opacity: 0.9; }

  .ladder-cap { font-size: 0.76rem; color: var(--muted); margin-top: 0.7rem; line-height: 1.5; }
  .ladder-cap b { color: var(--text); }
  .ladder-cap b.mat { color: var(--blue); }
  .ladder-cap b.pos { color: var(--purple); }
</style>
