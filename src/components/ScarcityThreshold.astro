---
/** Paso 1 · Eje de escasez (SVG estático) + demo interactiva del umbral. */
const items: [string, number, string][] = [
  ['Aire', 0.03, '🌬️'], ['Agua', 0.22, '💧'], ['Tierra', 0.45, '🏞️'],
  ['Vivienda', 0.6, '🏠'], ['Oro', 0.78, '🪙'], ['Diamantes', 0.88, '💎'], ['Atención', 0.96, '👁️'],
];
const W = 900, thr = 0.35;
let axis = `<line x1="60" y1="150" x2="${W - 30}" y2="150" stroke="#3a3a44" stroke-width="2"/>`;
axis += `<text x="60" y="185" fill="#52d053" font-size="13" font-family="monospace">◀ abundante (nadie lo acapara)</text>`;
axis += `<text x="${W - 30}" y="185" fill="#ff5555" font-size="13" font-family="monospace" text-anchor="end">escaso (se acapara) ▶</text>`;
const tx = 60 + (W - 90) * thr;
axis += `<line x1="${tx}" y1="40" x2="${tx}" y2="150" stroke="#ffcc33" stroke-width="1.6" stroke-dasharray="5,4"/>`;
axis += `<text x="${tx}" y="34" fill="#ffcc33" font-size="12" font-family="monospace" text-anchor="middle">umbral: aquí se enciende la máquina</text>`;
for (const [n, p, e] of items) {
  const px = 60 + (W - 90) * p; const col = p < thr ? '#52d053' : '#ed8d4c';
  axis += `<circle cx="${px}" cy="150" r="6" fill="${col}"/>`;
  axis += `<text x="${px}" y="128" font-size="20" text-anchor="middle">${e}</text>`;
  axis += `<text x="${px}" y="110" fill="${col}" font-size="12" font-family="monospace" text-anchor="middle">${n}</text>`;
}
---

<figure class="panel viz-fig">
  <div class="svg-scroll">
    <svg viewBox="0 0 900 220" set:html={axis}></svg>
  </div>
  <figcaption>Cuanto más escaso es algo, más lo peleamos y acaparamos. El aire nadie lo toca; los diamantes y
  la atención, sí. La línea es el umbral donde la máquina se enciende.</figcaption>
</figure>

<div class="thr panel">
  <label class="thr-lab">▸ Pruébalo: mueve la abundancia de recursos &nbsp; <b data-v></b></label>
  <input type="range" data-s min="0" max="100" value="70" aria-label="Abundancia de recursos" />
  <div class="thr-mode" data-mode>modo automático · mueve el control para tomar el mando</div>
  <canvas data-c></canvas>
  <div class="phase" data-st>···</div>
  <p class="thr-note">Baja la abundancia y observa: cruzando el umbral, la misma gente pasa de compartir
  tranquila a competir y acaparar. No cambió su moral; cambió la escasez.</p>
</div>

<script>
  import { ctxOf, COL } from '../lib/machine';

  const N = 28;          // personas
  const M = 40;          // recursos
  const THR = 45;        // umbral de escasez (coincide con el eje de arriba)
  const PICK = 9;        // radio para tomar un recurso al cruzarlo
  const BASE = 17;       // velocidad de deambular tranquilo (px/s)
  const H_MIN = 260;     // altura mínima del lienzo

  function init(root: HTMLElement) {
    const sl = root.querySelector<HTMLInputElement>('[data-s]')!;
    const lab = root.querySelector<HTMLElement>('[data-v]')!;
    const mode = root.querySelector<HTMLElement>('[data-mode]')!;
    const st = root.querySelector<HTMLElement>('[data-st]')!;
    const cv = root.querySelector<HTMLCanvasElement>('[data-c]')!;
    const measure = () =>
      ctxOf(cv, Math.max(H_MIN, Math.round(cv.getBoundingClientRect().height) || H_MIN));
    let g = measure();

    // PRNG determinista con semilla fija (LCG): NADA de Math.random por frame.
    let seed = 20260710 >>> 0;
    const rnd = () => { seed = (seed * 1664525 + 1013904223) >>> 0; return seed / 4294967296; };

    // Estado de personas (arrays preasignados, sin objetos por frame).
    const px = new Float32Array(N), py = new Float32Array(N);
    const vx = new Float32Array(N), vy = new Float32Array(N);
    const hd = new Float32Array(N);              // rumbo de deambular
    const wf = new Float32Array(N), wp = new Float32Array(N); // frecuencia/fase de vagabundeo
    const hunger = new Float32Array(N);          // tiempo sin recurso
    const stock = new Float32Array(N);           // recursos acumulados
    // Estado de recursos.
    const rx = new Float32Array(M), ry = new Float32Array(M);
    const alive = new Uint8Array(M);

    let lastW = 0, lastH = 0, laid = false, spawnAcc = 0;

    function targetActive(ab: number) {
      const f = Math.pow(Math.max(0, ab) / 100, 1.3);
      return Math.round(M * f);
    }

    function layout() {
      const { w, h } = g;
      for (let i = 0; i < N; i++) {
        px[i] = 0.06 * w + rnd() * 0.88 * w;
        py[i] = 0.08 * h + rnd() * 0.84 * h;
        hd[i] = rnd() * 6.283; vx[i] = 0; vy[i] = 0;
        wf[i] = 0.25 + rnd() * 0.7; wp[i] = rnd() * 6.283;
        hunger[i] = rnd() * 2; stock[i] = 0;
      }
      for (let j = 0; j < M; j++) { rx[j] = rnd() * w; ry[j] = rnd() * h; alive[j] = 0; }
      // Sembrar recursos iniciales según la abundancia de arranque.
      const want = targetActive(+sl.value);
      for (let j = 0; j < want && j < M; j++) { rx[j] = rnd() * w; ry[j] = rnd() * h; alive[j] = 1; }
      lastW = w; lastH = h; laid = true;
    }

    function spawn() {
      const { w, h } = g;
      for (let j = 0; j < M; j++) if (!alive[j]) { rx[j] = rnd() * w; ry[j] = rnd() * h; alive[j] = 1; return; }
    }

    // Modo ambiente: la abundancia oscila sola hasta que el usuario toma el control.
    let userTook = false;
    const t0 = performance.now();
    function ambientAb(now: number) {
      const s = 50 + 35 * Math.sin((now - t0) / 1000 * (Math.PI * 2 / 24)); // 24s, entre 15 y 85
      sl.value = String(Math.round(s));
      return s;
    }

    let lastPhase = '';
    function setPhase(ab: number, scarce: boolean) {
      const w = ab > 78 ? 'de sobra' : ab >= THR ? 'suficiente' : ab >= 20 ? 'escaso' : 'muy escaso';
      if (lab.textContent !== w) lab.textContent = w;
      const txt = !scarce
        ? '✓ MÁQUINA APAGADA: hay de sobra, la gente comparte y hasta se detiene a conversar'
        : ab >= 20
          ? '⚠️ MÁQUINA ENCENDIDA: los recursos escasean, empieza la carrera por tomarlos'
          : '💥 MÁQUINA A FONDO: frenesí, unos pocos amasan pilas y muchos parpadean en rojo';
      if (txt !== lastPhase) {
        lastPhase = txt; st.textContent = txt;
        const c = !scarce ? COL.green : ab >= 20 ? COL.orange : COL.red;
        st.style.color = c; st.style.borderColor = c;
      }
    }

    function drawPerson(i: number, scarce: boolean, t: number) {
      const { x } = g;
      const hoarder = stock[i] > 3;
      let col = COL.green, a = 1;
      if (hoarder) col = COL.orange;
      else if (scarce && hunger[i] > 4.5) { col = COL.red; a = 0.5 + 0.5 * Math.abs(Math.sin(t * 9)); }
      x.globalAlpha = a; x.fillStyle = col;
      x.beginPath(); x.arc(px[i], py[i] - 5, 4.4, 0, 7); x.fill();
      x.fillRect(px[i] - 3.4, py[i] - 1, 6.8, 9);
      x.globalAlpha = 1;
      if (hoarder) {
        x.fillStyle = COL.yellow;
        const blocks = Math.min(6, Math.floor(stock[i]) - 2);
        for (let k = 0; k < blocks; k++) x.fillRect(px[i] + 6, py[i] + 6 - k * 3.4, 6, 2.6);
      }
    }

    function frame(t: number, dt: number, ab: number) {
      if (!laid) layout();
      const { x, w, h } = g;
      const scarce = ab < THR;
      const s = scarce ? Math.min(1, (THR - ab) / THR) : 0; // intensidad de escasez 0..1
      const seek = 32 + s * 62;                              // aceleran hacia el recurso
      const resp = scarce ? 3 + s * 7 : 2.4;                 // qué tan brusco es el viraje

      // Reaparición de recursos a un ritmo controlado por la abundancia.
      let active = 0; for (let j = 0; j < M; j++) active += alive[j];
      spawnAcc += dt * (1 + (ab / 100) * 10);
      while (spawnAcc >= 1) { spawnAcc -= 1; if (active < targetActive(ab)) { spawn(); active++; } }

      x.clearRect(0, 0, w, h);

      // Recursos (puntitos verdes con leve halo).
      for (let j = 0; j < M; j++) if (alive[j]) {
        x.globalAlpha = 0.22; x.fillStyle = COL.green;
        x.beginPath(); x.arc(rx[j], ry[j], 5, 0, 7); x.fill();
        x.globalAlpha = 1;
        x.beginPath(); x.arc(rx[j], ry[j], 2.4, 0, 7); x.fill();
      }

      // Personas: buscar recurso, competir, deambular o conversar.
      for (let i = 0; i < N; i++) {
        hunger[i] += dt;
        stock[i] = Math.max(0, stock[i] - dt * 0.15); // las pilas se derriten al volver la abundancia

        // Recurso vivo más cercano.
        let bi = -1, bd = 1e9;
        for (let j = 0; j < M; j++) if (alive[j]) {
          const dx = rx[j] - px[i], dy = ry[j] - py[i], d2 = dx * dx + dy * dy;
          if (d2 < bd) { bd = d2; bi = j; }
        }
        const bdist = bi >= 0 ? Math.sqrt(bd) : 1e9;
        // El primero que llega lo toma (competencia): consumo inmediato.
        if (bi >= 0 && bdist < PICK) {
          alive[bi] = 0; hunger[i] = 0;
          if (scarce) stock[i] += 1; // bajo escasez lo acaparan; con abundancia lo consumen
          bi = -1;
        }

        let dvx: number, dvy: number;
        if (scarce && bi >= 0) {
          const dx = rx[bi] - px[i], dy = ry[bi] - py[i], d = Math.max(0.001, Math.sqrt(dx * dx + dy * dy));
          dvx = dx / d * seek; dvy = dy / d * seek;
        } else {
          // Abundancia: algunos pares se detienen a conversar; el resto deambula.
          const partner = i ^ 1;
          const chatting = Math.sin(t * 0.33 + (i >> 1) * 2.0) > 0.35;
          if (chatting) {
            const mx = (px[i] + px[partner]) / 2, my = (py[i] + py[partner]) / 2;
            const dx = mx - px[i], dy = my - py[i], d = Math.sqrt(dx * dx + dy * dy);
            const gap = Math.hypot(px[partner] - px[i], py[partner] - py[i]);
            const sp = gap < 16 ? 1.5 : BASE * 0.6;
            dvx = d > 0.001 ? dx / d * sp : 0; dvy = d > 0.001 ? dy / d * sp : 0;
          } else {
            hd[i] += Math.sin(t * wf[i] + wp[i]) * dt * 1.6;
            dvx = Math.cos(hd[i]) * BASE; dvy = Math.sin(hd[i]) * BASE;
          }
        }

        const k = Math.min(1, resp * dt);
        vx[i] += (dvx - vx[i]) * k; vy[i] += (dvy - vy[i]) * k;
        px[i] += vx[i] * dt; py[i] += vy[i] * dt;

        // Rebote en los bordes.
        const m = 8;
        if (px[i] < m) { px[i] = m; vx[i] = Math.abs(vx[i]); }
        else if (px[i] > w - m) { px[i] = w - m; vx[i] = -Math.abs(vx[i]); }
        if (py[i] < m) { py[i] = m; vy[i] = Math.abs(vy[i]); }
        else if (py[i] > h - m) { py[i] = h - m; vy[i] = -Math.abs(vy[i]); }
        if (vx[i] || vy[i]) hd[i] = Math.atan2(vy[i], vx[i]);
      }

      // Líneas de conversación (por encima, sutiles) solo en abundancia.
      if (!scarce) {
        x.strokeStyle = COL.blue; x.lineWidth = 1; x.globalAlpha = 0.25;
        for (let i = 0; i < N; i += 2) {
          if (Math.sin(t * 0.33 + (i >> 1) * 2.0) > 0.35) {
            const j = i ^ 1;
            if (Math.hypot(px[j] - px[i], py[j] - py[i]) < 26) {
              x.beginPath(); x.moveTo(px[i], py[i]); x.lineTo(px[j], py[j]); x.stroke();
            }
          }
        }
        x.globalAlpha = 1;
      }

      // Personas al frente.
      for (let i = 0; i < N; i++) drawPerson(i, scarce, t);

      setPhase(ab, scarce);
    }

    // Render estático (prefers-reduced-motion): rejilla coloreada según el control.
    function staticGrid() {
      if (!laid) { g = measure(); }
      const { x, w, h } = g; x.clearRect(0, 0, w, h);
      const ab = +sl.value, scarce = ab < THR, frac = scarce ? Math.min(1, (THR - ab) / THR) : 0;
      const cols = 7, rows = 4, cw = w / cols, ch = (h - 12) / rows, hoarders = Math.round(frac * N);
      for (let i = 0; i < N; i++) {
        const cx = (i % cols) * cw + cw / 2, cy = Math.floor(i / cols) * ch + ch / 2 + 8;
        const hoard = i < hoarders, red = scarce && i >= hoarders && i < hoarders + Math.round(frac * 6);
        x.fillStyle = hoard ? COL.orange : red ? COL.red : COL.green;
        x.beginPath(); x.arc(cx, cy - 5, 4.4, 0, 7); x.fill(); x.fillRect(cx - 3.4, cy - 1, 6.8, 9);
        if (hoard) { x.fillStyle = COL.yellow; for (let k = 0; k < 3; k++) x.fillRect(cx + 6, cy + 6 - k * 3.4, 6, 2.6); }
      }
      setPhase(ab, scarce);
    }

    sl.addEventListener('input', () => { userTook = true; mode.style.display = 'none'; });

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      mode.style.display = 'none';
      layout(); staticGrid();
      sl.addEventListener('input', staticGrid);
      window.addEventListener('resize', () => { g = measure(); staticGrid(); });
      return;
    }

    let last = performance.now();
    function tick(now: number) {
      const dt = Math.min(0.05, (now - last) / 1000); last = now;
      const t = now / 1000;
      const ab = userTook ? +sl.value : ambientAb(now);
      frame(t, dt, ab);
      requestAnimationFrame(tick);
    }
    window.addEventListener('resize', () => {
      const ng = measure();
      if (laid && lastW > 0 && lastH > 0) {
        const sxw = ng.w / lastW, syh = ng.h / lastH;
        for (let i = 0; i < N; i++) { px[i] *= sxw; py[i] *= syh; }
        for (let j = 0; j < M; j++) { rx[j] *= sxw; ry[j] *= syh; }
      }
      lastW = ng.w; lastH = ng.h; g = ng;
    });
    requestAnimationFrame(tick);
  }
  document.querySelectorAll<HTMLElement>('.thr').forEach(init);
</script>

<style>
  .viz-fig { padding: 1rem 1.2rem 0.8rem; margin-block: 1.5rem; }
  .viz-fig figcaption { font-size: 0.78rem; color: var(--muted); margin-top: 0.6rem; }
  .svg-scroll { overflow-x: auto; -webkit-overflow-scrolling: touch; }
  .svg-scroll svg { display: block; width: 100%; }
  @media (max-width: 700px) {
    /* En mobile el eje mantiene un ancho legible y se desplaza a lo ancho. */
    .svg-scroll svg { min-width: 640px; }
  }
  .thr { padding: 1rem 1.2rem; margin-block: 1.5rem; }
  .thr-lab { display: block; font-size: 0.72rem; color: var(--muted); margin-bottom: 0.4rem; }
  .thr-lab b { color: var(--blue); }
  .thr input { width: 100%; accent-color: var(--orange); }
  .thr-mode { font-size: 0.62rem; letter-spacing: 0.06em; color: var(--muted); opacity: 0.75; margin-top: 0.35rem; }
  .thr canvas { display: block; width: 100%; height: 260px; margin-top: 0.6rem; background: rgba(0,0,0,0.18); }
  .phase { font-size: 0.74rem; letter-spacing: 0.12em; border: 1px solid; padding: 0.5rem 0.7rem; margin-top: 0.7rem; }
  .thr-note { font-size: 0.74rem; color: var(--muted); margin-top: 0.7rem; }
  @media (min-width: 900px) {
    .thr canvas { height: clamp(260px, 40vh, 420px); }
  }
</style>
