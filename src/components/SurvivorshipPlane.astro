---
/**
 * Sesgo de supervivencia: el bombardero de Abraham Wald (1943).
 * Tres pasos: los datos (impactos de los que volvieron), la lectura
 * ingenua (blindar donde hay agujeros) y la inversión de Wald
 * (blindar donde NO los hay: motores y cabina).
 */
---

<figure class="splane panel">
  <div class="splane-head">
    <span class="splane-title">◢ El avión que volvió</span>
    <span class="splane-phase" data-phase>PASO 1/3</span>
  </div>
  <div class="splane-steps">
    <button data-step="0" class="on">1 · Los datos</button>
    <button data-step="1">2 · La lectura ingenua</button>
    <button data-step="2">3 · La lectura de Wald</button>
  </div>
  <div class="splane-wrap">
    <svg data-svg viewBox="0 0 640 400" role="img" aria-label="Vista superior de un bombardero con los impactos de bala de los aviones que regresaron"></svg>
  </div>
  <div class="splane-hint">▸ toca el avión para avanzar</div>
  <div class="splane-legend">
    <span><i class="lg-hit"></i>impacto registrado (sobrevivientes)</span>
    <span><i class="lg-ghost"></i>impactos que nunca volvieron (paso 3)</span>
  </div>
  <div class="readout" data-ro></div>
  <figcaption class="splane-refs">
    Abraham Wald (1943), <i>&ldquo;A Method of Estimating Plane Vulnerability Based on Damage of Survivors&rdquo;</i>,
    Statistical Research Group, Universidad de Columbia (memorandos desclasificados; reeditados por el
    Center for Naval Analyses, 1980) · Mangel &amp; Samaniego (1984), <i>Journal of the American Statistical Association</i>.
  </figcaption>
  <div class="splane-foot">SOLO VES A LOS QUE VOLVIERON · LOS DATOS QUE FALTAN SON LA LECCIÓN</div>
</figure>

<script>
  type Rect = { x: number; y: number; w: number; h: number };
  type Pt = { x: number; y: number };

  const NS = 'http://www.w3.org/2000/svg';
  function el(tag: string, attrs: Record<string, string | number>, parent: Element): SVGElement {
    const n = document.createElementNS(NS, tag);
    for (const k in attrs) n.setAttribute(k, String(attrs[k]));
    parent.appendChild(n);
    return n as SVGElement;
  }

  /** PRNG determinista (mulberry32): los puntos son siempre los mismos. */
  function rng(seed: number): () => number {
    return () => {
      seed |= 0; seed = (seed + 0x6d2b79f5) | 0;
      let t = Math.imul(seed ^ (seed >>> 15), 1 | seed);
      t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
      return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
    };
  }

  // ── Geometría (viewBox 640×400, nariz a la izquierda, eje en y=200) ──
  // Ala: borde de ataque raíz→punta (195,±20)→(255,±180 de recorrido);
  // parametrizada por t∈[0,1]: lead x=195+60t, trail x=315-15t, |y-200|=20+160t.
  const leadX = (t: number) => 195 + 60 * t;
  const trailX = (t: number) => 315 - 15 * t;
  const wingY = (t: number, side: 1 | -1) => 200 - side * (20 + 160 * t);

  // Góndolas de motor (2 por ala; se reflejan abajo).
  const NAC_TOP: Rect[] = [
    { x: 197, y: 122, w: 64, h: 26 },
    { x: 214, y: 70, w: 60, h: 26 },
  ];
  const NACS: Rect[] = [
    ...NAC_TOP,
    ...NAC_TOP.map((r) => ({ x: r.x, y: 400 - r.y - r.h, w: r.w, h: r.h })),
  ];
  const COCKPIT: Rect = { x: 88, y: 183, w: 46, h: 34 };

  function inRect(p: Pt, r: Rect, pad: number): boolean {
    return p.x >= r.x - pad && p.x <= r.x + r.w + pad && p.y >= r.y - pad && p.y <= r.y + r.h + pad;
  }
  const hitsNacelle = (p: Pt) => NACS.some((r) => inRect(p, r, 5));

  // ── Puntos deterministas ──
  const R = rng(19430704);
  const HITS: Pt[] = [];
  // Mitad exterior de las alas (t ≥ 0.45), esquivando las góndolas.
  for (const side of [1, -1] as const) {
    let n = 0, guard = 0;
    while (n < 24 && guard++ < 500) {
      const t = 0.45 + R() * 0.52;
      const s = 0.08 + R() * 0.84;
      const p = { x: leadX(t) + s * (trailX(t) - leadX(t)), y: wingY(t, side) };
      if (hitsNacelle(p)) continue;
      HITS.push(p); n++;
    }
  }
  // Fuselaje trasero (detrás del ala, hasta antes de la cola).
  for (let n = 0; n < 14; n++) {
    const x = 380 + R() * 160;
    const hw = 20 - (12 * (x - 300)) / 260; // el fuselaje se estrecha hacia la cola
    HITS.push({ x, y: 200 + (R() * 2 - 1) * hw * 0.8 });
  }
  // Bordes de los estabilizadores de cola.
  for (let n = 0; n < 8; n++) {
    const side = n % 2 === 0 ? 1 : -1;
    const t = 0.25 + R() * 0.65;
    const lx = 525 + 30 * t, tx = 585 - 10 * t;
    const x = R() < 0.5 ? lx + R() * 0.25 * (tx - lx) : tx - R() * 0.25 * (tx - lx);
    HITS.push({ x, y: 200 - side * (15 + 65 * t) });
  }

  // Impactos "fantasma": lo que recibieron los aviones que no volvieron.
  const GHOSTS: Pt[] = [];
  for (const r of NACS)
    for (let n = 0; n < 5; n++)
      GHOSTS.push({ x: r.x + 6 + R() * (r.w - 12), y: r.y + 5 + R() * (r.h - 10) });
  for (let n = 0; n < 5; n++)
    GHOSTS.push({ x: COCKPIT.x + 6 + R() * (COCKPIT.w - 12), y: COCKPIT.y + 6 + R() * (COCKPIT.h - 12) });
  for (const side of [1, -1] as const) {
    let n = 0, guard = 0;
    while (n < 4 && guard++ < 200) {
      const t = 0.06 + R() * 0.26;
      const s = 0.15 + R() * 0.7;
      const p = { x: leadX(t) + s * (trailX(t) - leadX(t)), y: wingY(t, side) };
      if (hitsNacelle(p)) continue;
      GHOSTS.push(p); n++;
    }
  }

  const TEXTS: string[] = [
    'En <b>1943</b>, el <b>Statistical Research Group</b> de la Universidad de Columbia mapeó los impactos de bala de los bombarderos <b>que volvieron</b> de misión. El patrón era nítido: los agujeros se acumulan en las <b>alas</b>, el <b>fuselaje trasero</b> y la <b>cola</b>.',
    'La lectura ingenua del mando: <b>&ldquo;blindemos donde hay agujeros&rdquo;</b>, es decir, reforzar alas y cola, que es donde se concentran los impactos. Parece obvio. Y está <b>exactamente al revés</b>.',
    '<b>Abraham Wald</b> invirtió la muestra: los datos venían <b>solo de los sobrevivientes</b>. Los aviones alcanzados en <b>motores</b> y <b>cabina</b> no volvieron para ser contados. El blindaje va donde <b>NO</b> ves agujeros: los agujeros que faltan son los aviones que faltan.',
  ];

  function init(root: HTMLElement) {
    const svg = root.querySelector<SVGSVGElement>('[data-svg]')!;
    const ro = root.querySelector<HTMLElement>('[data-ro]')!;
    const phase = root.querySelector<HTMLElement>('[data-phase]')!;
    const btns = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-step]'));

    // ── Silueta del bombardero (vista superior) ──
    const gPlane = el('g', {}, svg);
    const wing = { fill: 'rgba(255,255,255,0.04)', stroke: '#8f8b83', 'stroke-width': 1.3 };
    el('polygon', { points: '195,180 255,20 300,20 315,180', ...wing }, gPlane);
    el('polygon', { points: '195,220 255,380 300,380 315,220', ...wing }, gPlane);
    el('polygon', { points: '525,185 555,120 575,120 585,185', ...wing }, gPlane);
    el('polygon', { points: '525,215 555,280 575,280 585,215', ...wing }, gPlane);
    // Deriva (aleta vertical vista desde arriba) y fuselaje.
    el('ellipse', { cx: 566, cy: 200, rx: 30, ry: 4.5, ...wing }, gPlane);
    el('path', {
      d: 'M 70 180 L 300 180 L 560 192 Q 600 196 600 200 Q 600 204 560 208 L 300 220 L 70 220 Q 34 200 70 180 Z',
      fill: 'rgba(255,255,255,0.05)', stroke: '#8f8b83', 'stroke-width': 1.5,
    }, gPlane);
    // Góndolas de motor y cabina.
    for (const r of NACS)
      el('rect', { x: r.x, y: r.y, width: r.w, height: r.h, rx: 9, fill: 'rgba(255,255,255,0.06)', stroke: '#8f8b83', 'stroke-width': 1.2 }, gPlane);
    el('rect', { x: COCKPIT.x, y: COCKPIT.y, width: COCKPIT.w, height: COCKPIT.h, rx: 11, fill: 'rgba(51,183,219,0.08)', stroke: '#8f8b83', 'stroke-width': 1.2 }, gPlane);

    // ── Capas de los pasos ──
    // Paso 2: anillos naranjas sobre las zonas CON agujeros.
    const gRings = el('g', { class: 'fade', opacity: 0 }, svg);
    const ring = { fill: 'rgba(237,141,76,0.06)', stroke: '#ed8d4c', 'stroke-width': 1.6, 'stroke-dasharray': '6 4' };
    el('ellipse', { cx: 268, cy: 66, rx: 52, ry: 58, ...ring }, gRings);
    el('ellipse', { cx: 268, cy: 334, rx: 52, ry: 58, ...ring }, gRings);
    el('ellipse', { cx: 458, cy: 200, rx: 92, ry: 30, ...ring }, gRings);
    el('ellipse', { cx: 556, cy: 200, rx: 44, ry: 96, ...ring }, gRings);

    // Paso 3: zonas SIN agujeros (motores, cabina, tanques) + fantasmas.
    const gSafe = el('g', { class: 'fade', opacity: 0 }, svg);
    for (const r of NACS)
      el('rect', { x: r.x - 5, y: r.y - 5, width: r.w + 10, height: r.h + 10, rx: 12, fill: 'rgba(82,208,83,0.08)', stroke: '#52d053', 'stroke-width': 1.5, 'stroke-dasharray': '4 3' }, gSafe);
    el('rect', { x: COCKPIT.x - 5, y: COCKPIT.y - 5, width: COCKPIT.w + 10, height: COCKPIT.h + 10, rx: 13, fill: 'rgba(255,204,51,0.08)', stroke: '#ffcc33', 'stroke-width': 1.5, 'stroke-dasharray': '4 3' }, gSafe);
    el('ellipse', { cx: 254, cy: 152, rx: 50, ry: 30, fill: 'rgba(255,204,51,0.05)', stroke: '#ffcc33', 'stroke-width': 1.2, 'stroke-dasharray': '4 3' }, gSafe);
    el('ellipse', { cx: 254, cy: 248, rx: 50, ry: 30, fill: 'rgba(255,204,51,0.05)', stroke: '#ffcc33', 'stroke-width': 1.2, 'stroke-dasharray': '4 3' }, gSafe);
    const lbl = { 'font-family': 'JetBrains Mono, monospace', 'font-size': 10, 'text-anchor': 'middle' };
    el('text', { x: 111, y: 172, fill: '#ffcc33', ...lbl }, gSafe).textContent = 'cabina';
    el('text', { x: 244, y: 54, fill: '#52d053', ...lbl }, gSafe).textContent = 'motores';
    el('text', { x: 244, y: 352, fill: '#52d053', ...lbl }, gSafe).textContent = 'motores';
    el('text', { x: 340, y: 152, fill: '#ffcc33', ...lbl }, gSafe).textContent = 'tanques';

    const gGhost = el('g', { class: 'fade', opacity: 0 }, svg);
    for (const p of GHOSTS)
      el('circle', { cx: p.x, cy: p.y, r: 3, fill: 'none', stroke: '#ffcc33', 'stroke-width': 1.2, 'stroke-dasharray': '2 2', opacity: 0.7 }, gGhost);

    // Paso 1 (siempre visibles, se atenúan en el 3): impactos reales.
    const gHits = el('g', { class: 'fade' }, svg);
    for (const p of HITS)
      el('circle', { cx: p.x, cy: p.y, r: 3, fill: '#ff5555', opacity: 0.95 }, gHits);

    let cur = 0;
    function setStep(i: number) {
      cur = i;
      btns.forEach((b, k) => b.classList.toggle('on', k === i));
      phase.textContent = `PASO ${i + 1}/3`;
      phase.style.color = i === 2 ? '#52d053' : i === 1 ? '#ed8d4c' : '#8f8b83';
      gRings.style.opacity = i === 1 ? '1' : '0';
      gSafe.style.opacity = i === 2 ? '1' : '0';
      gGhost.style.opacity = i === 2 ? '1' : '0';
      gHits.style.opacity = i === 2 ? '0.22' : '1';
      ro.innerHTML = TEXTS[i];
    }
    btns.forEach((b) => (b.onclick = () => setStep(+b.dataset.step!)));
    // Tocar el propio avión avanza al siguiente paso (cíclico 1→2→3→1).
    svg.addEventListener('click', () => setStep((cur + 1) % 3));
    setStep(0);
  }
  document.querySelectorAll<HTMLElement>('.splane').forEach(init);
</script>

<style>
  .splane { padding: 1rem 1.2rem 0.8rem; margin-block: 2.5rem; }
  .splane-head { display: flex; justify-content: space-between; align-items: baseline; gap: 1rem; flex-wrap: wrap; margin-bottom: 0.9rem; }
  .splane-title { color: var(--orange-bright); font-size: 0.78rem; letter-spacing: 0.3em; text-transform: uppercase; }
  .splane-phase { font-size: 0.68rem; letter-spacing: 0.2em; color: var(--muted); }
  .splane-steps { display: flex; gap: 0.4rem; flex-wrap: wrap; margin-bottom: 0.9rem; }
  .splane-steps button {
    background: var(--bg-panel-2); color: var(--text); border: 1px solid var(--line);
    padding: 0.4rem 0.7rem; font-family: var(--font-mono); font-size: 0.7rem;
    letter-spacing: 0.08em; cursor: pointer;
  }
  .splane-steps button:hover { border-color: var(--orange); color: var(--orange-bright); }
  .splane-steps button.on { background: var(--orange); color: #000; font-weight: 700; border-color: var(--orange); }
  .splane-wrap { overflow-x: auto; }
  .splane-wrap svg { display: block; width: 100%; height: auto; cursor: pointer; }
  .splane-hint { margin-top: 0.35rem; font-size: 0.6rem; letter-spacing: 0.14em; color: var(--muted); text-transform: uppercase; }
  .splane-wrap :global(.fade) { transition: opacity 0.45s ease; }
  .splane-legend { display: flex; gap: 1.2rem; flex-wrap: wrap; font-size: 0.66rem; color: var(--muted); margin-top: 0.5rem; }
  .splane-legend i { width: 10px; height: 10px; border-radius: 50%; display: inline-block; margin-right: 0.5ch; vertical-align: middle; }
  .lg-hit { background: #ff5555; }
  .lg-ghost { background: transparent; border: 1.5px dashed var(--yellow, #ffcc33); }
  .readout { font-size: 0.78rem; color: var(--muted); background: var(--bg-deep); border: 1px solid var(--line); padding: 0.65rem 0.8rem; margin-top: 0.8rem; line-height: 1.7; min-height: 5.2em; }
  .readout :global(b) { color: var(--text); }
  .splane-refs { margin-top: 0.7rem; font-size: 0.62rem; color: var(--muted); line-height: 1.6; }
  .splane-foot { margin-top: 0.7rem; padding-top: 0.5rem; border-top: 1px dashed var(--line); font-size: 0.6rem; letter-spacing: 0.28em; color: var(--muted); }
  @media (max-width: 700px) {
    .splane-wrap svg { min-width: 640px; }
  }
  /* Tratamiento hero: página completa en escritorio. */
  @media (min-width: 900px) {
    .splane {
      min-height: 92vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 1.4rem 2rem 1rem;
    }
    .splane-wrap { display: flex; justify-content: center; }
    .splane-wrap svg {
      width: auto;
      height: clamp(400px, 62vh, 820px);
      min-height: 400px;
      max-height: 65vh;
      max-width: min(100%, 1100px);
      margin-inline: auto;
    }
    .splane-title { font-size: 0.92rem; }
    .splane-phase { font-size: 0.78rem; }
    .splane-steps { gap: 0.55rem; }
    .splane-steps button { padding: 0.6rem 1.1rem; font-size: 0.85rem; }
    .splane-hint { font-size: 0.68rem; text-align: center; margin-top: 0.5rem; }
    .splane-legend { font-size: 0.74rem; justify-content: center; margin-top: 0.7rem; }
    .readout { font-size: 0.92rem; max-width: 80ch; margin-inline: auto; width: 100%; }
    .splane-refs { font-size: 0.7rem; }
    .splane-foot { font-size: 0.66rem; }
  }
</style>
