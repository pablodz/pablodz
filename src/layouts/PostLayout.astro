---
import BaseLayout from './BaseLayout.astro';
import { url, formatDate, pad } from '../utils';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date | undefined;
  tags: string[];
  episode: number;
}

const { title, description, pubDate, updatedDate, tags, episode } = Astro.props;
---

<BaseLayout title={`${title} — Pablo Diaz`} description={description}>
  <article>
    <div class="title-card">
      <div class="wrap">
        <p class="episode-no">LOG:{pad(episode)}</p>
        <h1 class="episode-title">{title.toUpperCase()}</h1>
        <p class="episode-desc">{description}</p>
        <div class="meta">
          <span class="t-label t-label--orange">DATE {formatDate(pubDate)}</span>
          {updatedDate && <span class="t-label">UPDATED {formatDate(updatedDate)}</span>}
          {tags.map((tag) => <span class="t-label t-label--purple">#{tag}</span>)}
        </div>
      </div>
      <div class="hazard" aria-hidden="true"></div>
    </div>

    <div class="wrap">
      <div class="prose">
        <slot />
      </div>

      <div class="post-end">
        <p class="end-text">— FIN DE LA TRANSMISIÓN —</p>
        <a href={url('/')} class="back">◀ VOLVER A LOS ARCHIVOS</a>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .title-card {
    background: #000;
    margin-bottom: 3rem;
  }

  .title-card .wrap {
    padding-block: 3.5rem 2.5rem;
  }

  .episode-no {
    font-size: 0.75rem;
    letter-spacing: 0.5em;
    color: var(--orange-bright);
    margin-bottom: 1rem;
  }

  .episode-title {
    font-size: clamp(1.8rem, 5vw, 3.2rem);
    color: #fff;
    margin-bottom: 1rem;
  }

  @media (prefers-reduced-motion: no-preference) {
    .episode-no {
      animation: cut-in 0.35s steps(1, end) both;
    }
    .episode-title {
      animation: cut-in 0.5s steps(1, end) 0.1s both;
    }
    .episode-desc,
    .meta {
      animation: cut-in 0.4s steps(1, end) 0.35s both;
    }
  }

  .episode-desc {
    color: var(--muted);
    font-size: 0.92rem;
    margin-bottom: 1.4rem;
  }

  .meta {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .post-end {
    margin-top: 4rem;
    text-align: center;
  }

  .end-text {
    letter-spacing: 0.4em;
    font-size: 0.72rem;
    color: var(--muted);
    padding-top: 1.4rem;
    border-top: 1px solid var(--line);
    margin-bottom: 1rem;
  }

  .back {
    font-size: 0.78rem;
    letter-spacing: 0.2em;
  }
</style>
