---
import BaseLayout from '../layouts/BaseLayout.astro';
import { url } from '../utils';
---

<BaseLayout title="404 · Pablo Diaz">
  <section class="wrap">
    <p class="code">ERROR:404</p>
    <h1>SEÑAL NO ENCONTRADA</h1>
    <p class="hint">El registro que buscas no existe o fue purgado del archivo.</p>
    <a href={url('/')} class="back">◀ VOLVER A LOS ARCHIVOS</a>
  </section>
</BaseLayout>

<style>
  section {
    padding-block: 6rem;
  }

  .code {
    font-size: 0.75rem;
    letter-spacing: 0.5em;
    color: var(--red);
    margin-bottom: 1rem;
  }

  h1 {
    font-size: clamp(2rem, 6vw, 3.5rem);
    color: #fff;
    margin-bottom: 1rem;
  }

  @media (prefers-reduced-motion: no-preference) {
    h1 {
      animation: cut-in 0.5s steps(1, end) both;
    }
  }

  .hint {
    color: var(--muted);
    font-size: 0.9rem;
    margin-bottom: 2rem;
  }

  .back {
    font-size: 0.78rem;
    letter-spacing: 0.2em;
  }
</style>
